---
import Logo from "./Logo.astro";

const navLinks = [
  { href: "/", label: "Home" },
  { href: "/clubs", label: "Clubs" },
  { href: "/evenementen", label: "Evenementen" },
  { href: "/sponsors", label: "Sponsors" },
  { href: "/add-club", label: "Voeg je club toe" },
];

const currentPath = Astro.url.pathname;
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 group">
        <Logo className="w-8 h-8 text-primary-500" />
        <div>
          <span class="font-bold text-gray-900 text-sm leading-tight block"
            >WielerWaas</span
          >
          <span class="text-xs text-gray-400 leading-tight block"
            >Wielrennen in het Waasland</span
          >
        </div>
      </a>

      <nav class="hidden md:flex items-center gap-1">
        {
          navLinks.map((link) => (
            <a
              href={link.href}
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                currentPath === link.href
                  ? "bg-primary-50 text-primary-700"
                  : "text-gray-600 hover:text-gray-900 hover:bg-gray-50"
              } ${link.label === "Voeg je club toe" ? "!bg-accent-600 !text-white hover:!bg-accent-700 ml-2" : ""}`}
            >
              {link.label}
            </a>
          ))
        }
      </nav>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100"
        aria-label="Menu"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-gray-100 bg-white"
  >
    <nav class="px-4 py-3 flex flex-col gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
              currentPath === link.href
                ? "bg-primary-50 text-primary-700"
                : "text-gray-600 hover:text-gray-900 hover:bg-gray-50"
            } ${link.label === "Voeg je club toe" ? "!bg-accent-600 !text-white mt-1" : ""}`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
