---
const navLinks = [
  { href: "/", label: "Home" },
  { href: "/clubs", label: "Clubs" },
  { href: "/evenementen", label: "Evenementen" },
  { href: "/sponsors", label: "Sponsors" },
  { href: "/over-ons", label: "Over ons" },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header class="ww-header">
  <div class="ww-wrap ww-hdr">
    <a href="/" class="ww-brand">
      <svg width="44" height="18" aria-hidden="true">
        <use href="#ww-bike"></use>
      </svg>
      <div>
        <div class="ww-brand-txt">Wieler<em>Waas</em></div>
        <div class="ww-brand-sub">Wielrennen · het Waasland</div>
      </div>
    </a>

    <nav class="ww-nav" aria-label="Hoofdnavigatie">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class={isActive(link.href) ? "active" : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/add-club"
        class={`cta ${isActive("/add-club") ? "active" : ""}`}
      >
        + Voeg je club toe
      </a>
    </nav>

    <button id="mobile-menu-btn" class="ww-menu-btn" aria-label="Menu">
      <svg
        class="w-5 h-5"
        width="20"
        height="20"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div id="mobile-menu" class="ww-mobile-menu">
    {
      navLinks.map((link) => (
        <a href={link.href} class={isActive(link.href) ? "active" : undefined}>
          {link.label}
        </a>
      ))
    }
    <a href="/add-club" class="cta">+ Voeg je club toe</a>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    btn?.addEventListener("click", () => menu?.classList.toggle("open"));
  }

  document.addEventListener("astro:page-load", initMobileMenu);
</script>
