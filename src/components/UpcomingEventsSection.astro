---
import EventCard from "./EventCard.astro";
import type { EventOccurrence } from "../utils/events";

interface Props {
  upcomingEvents: EventOccurrence[];
}

const { upcomingEvents } = Astro.props;
---

{
  upcomingEvents.length > 0 && (
    <section class="ww-band white">
      <div class="ww-wrap">
        <header class="ww-section-head">
          <div>
            <div class="num">03</div>
            <h2>
              Aankomende <em>evenementen</em>
            </h2>
            <div class="sub">Ritten en evenementen van clubs in de regio</div>
          </div>
          <a href="/evenementen" class="link" title="Bekijk alle evenementen">
            Alle evenementen →
          </a>
        </header>

        <div class="ww-events-grid">
          {upcomingEvents.map((event) => (
            <EventCard
              name={event.event.data.name}
              date={event.occurrenceDate}
              frequency={event.event.data.frequency}
              time={event.event.data.time}
              organizer={event.event.data.organizer}
              location={event.event.data.location}
              website={event.event.data.website}
              slug={event.event.id}
            />
          ))}
        </div>
      </div>
    </section>
  )
}
