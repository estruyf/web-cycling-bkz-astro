---
interface Props {
  variant?: "dark" | "light";
  title?: string;
  description?: string;
  cta?: "club" | "event" | "both";
}

const {
  variant = "dark",
  title = "Staat jouw club er nog niet bij?",
  description = "Zet jouw club in de kijker bij lokale fietsers. Het kost maar een paar minuten om je gegevens door te sturen. We publiceren zo snel mogelijk.",
  cta = "both",
} = Astro.props;
---

{
  variant === "dark" ? (
    <section class="ww-cta-band">
      <svg class="wheels-cta" width="420" height="210" aria-hidden="true">
        <use href="#ww-wheels-big" />
      </svg>
      <div class="ww-wrap">
        <div>
          <h2 class="max-w-2/3">{title}</h2>
          <p>{description}</p>
        </div>
        <div class="ww-cta-actions">
          {(cta === "club" || cta === "both") && (
            <a href="/add-club" class="ww-btn ww-btn-chalk" title="Voeg je club toe">
              Voeg je club toe →
            </a>
          )}
          {(cta === "event" || cta === "both") && (
            <a href="/add-event" class="ww-btn ww-btn-outline-chalk" title="Voeg je evenement toe">
              Voeg je evenement toe
            </a>
          )}
        </div>
      </div>
    </section>
  ) : (
    <div class="ww-card" style="text-align:center; margin-top: 24px;">
      <h3 style="font-family:'Anton',sans-serif; font-size:28px; text-transform:uppercase; letter-spacing:0.02em; margin:0 0 10px; font-weight:400;">
        {title}
      </h3>
      <p style="color: var(--mute); margin: 0 0 18px; font-size: 14px;">
        {description}
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center;">
        {(cta === "club" || cta === "both") && (
          <a href="/add-club" class="ww-btn ww-btn-red" title="Voeg je club toe">
            Voeg je club toe →
          </a>
        )}
        {(cta === "event" || cta === "both") && (
          <a href="/add-event" class="ww-btn ww-btn-outline-ink" title="Voeg je evenement toe">
            Voeg je evenement toe
          </a>
        )}
      </div>
    </div>
  )
}
