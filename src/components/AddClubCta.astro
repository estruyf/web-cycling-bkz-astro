---
interface Props {
  variant?: "dark" | "light";
  title?: string;
  description?: string;
  buttonText?: string;
}

const {
  variant = "dark",
  title = "Staat jouw club er nog niet bij?",
  description = "Zet jouw club in de kijker bij lokale fietsers. Het kost maar een paar minuten om je gegevens door te sturen.",
  buttonText = "Voeg je club toe",
} = Astro.props;

const isDark = variant === "dark";
---

{
  isDark ? (
    <section class="bg-primary-900 text-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-3">{title}</h2>
        <p class="text-primary-200 mb-7 max-w-xl mx-auto">{description}</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a
            href="/add-club"
            class="inline-flex items-center gap-2 bg-accent-500 text-primary-900 hover:bg-accent-400 font-semibold px-7 py-3 rounded-xl transition-colors"
          >
            {buttonText}
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </a>
          <a
            href="/add-event"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold px-7 py-3 rounded-xl transition-colors"
          >
            Voeg je evenement toe
          </a>
        </div>
      </div>
    </section>
  ) : (
    <div class="mt-4 bg-primary-50 border border-primary-100 rounded-2xl p-8 text-center">
      <h3 class="text-lg font-bold text-gray-900 mb-2">{title}</h3>
      <p class="text-gray-500 mb-5 text-sm">{description}</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a
          href="/add-club"
          class="inline-flex items-center gap-2 bg-accent-600 hover:bg-accent-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm"
        >
          {buttonText}
        </a>
        <a
          href="/add-event"
          class="inline-flex items-center gap-2 border border-primary-200 text-primary-700 hover:bg-primary-100 font-semibold px-6 py-3 rounded-xl transition-colors text-sm"
        >
          Voeg je evenement toe
        </a>
      </div>
    </div>
  )
}
