---
import type { Club, WeekritOverzicht } from "../models";

interface Props {
  clubs: Club[];
}

const { clubs } = Astro.props;

const dagNamen: Record<string, string> = {
  Monday: "Maandag",
  Tuesday: "Dinsdag",
  Wednesday: "Woensdag",
  Thursday: "Donderdag",
  Friday: "Vrijdag",
  Saturday: "Zaterdag",
  Sunday: "Zondag",
};

const dayOrder = [
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
  "Sunday",
];

const alleRitten: WeekritOverzicht[] = clubs.flatMap((club) =>
  club.data.rides.map((ride) => ({
    clubNaam: club.data.name,
    clubSlug: club.id.replace(/\.md$/, ""),
    dag: ride.day,
    uur: ride.time,
    type: ride.type,
    groep: ride.group,
    gemiddeldeSnelheid: ride.averageSpeed,
    vertrekpunt: club.data.meetingPoint,
    openVoorIedereen: ride.openForAll,
  })),
);

const gesorteerdeRitten = alleRitten.sort((a, b) => {
  const dagVerschil = dayOrder.indexOf(a.dag) - dayOrder.indexOf(b.dag);
  if (dagVerschil !== 0) return dagVerschil;
  return a.uur.localeCompare(b.uur);
});

function formatSpeed(speed?: number): string | undefined {
  return speed != null ? `${speed} km/u` : undefined;
}
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Wekelijkse ritten</h2>
      <p class="text-gray-500 text-sm mt-1">
        Alle geplande ritten van alle clubs
      </p>
    </div>
    <a
      href="/clubs"
      class="text-primary-500 hover:text-primary-600 text-sm font-medium flex items-center gap-1"
    >
      Alle clubs
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
        ></path>
      </svg>
    </a>
  </div>

  <div class="flex flex-wrap gap-3 mb-4">
    <select
      id="filter-dag"
      class="text-sm border border-gray-200 rounded-lg px-3 py-2 bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-primary-300"
    >
      <option value="">Alle dagen</option>
      {dayOrder.map((day) => <option value={day}>{dagNamen[day]}</option>)}
    </select>

    <label
      class="inline-flex items-center gap-2 text-sm text-gray-700 border border-gray-200 rounded-lg px-3 py-2 bg-white cursor-pointer select-none"
    >
      <input
        id="filter-open"
        type="checkbox"
        class="w-4 h-4 accent-primary-600"
      />
      Alleen open voor iedereen
    </label>

    <button
      id="filter-reset"
      class="hidden text-sm text-gray-500 hover:text-gray-800 border border-gray-200 rounded-lg px-3 py-2 bg-white transition-colors"
    >
      Filters wissen
    </button>
  </div>

  <div
    class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden"
  >
    <div class="overflow-x-auto">
      <table class="w-full text-sm" id="rides-table">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-200">
            <th class="text-left py-3.5 px-5 font-semibold text-gray-600"
              >Dag</th
            >
            <th class="text-left py-3.5 px-5 font-semibold text-gray-600"
              >Uur</th
            >
            <th class="text-left py-3.5 px-5 font-semibold text-gray-600"
              >Club</th
            >
            <th
              class="text-left py-3.5 px-5 font-semibold text-gray-600 hidden sm:table-cell"
              >Type rit</th
            >
            <th
              class="text-left py-3.5 px-5 font-semibold text-gray-600 hidden md:table-cell"
              >Groep</th
            >
            <th
              class="text-left py-3.5 px-5 font-semibold text-gray-600 hidden md:table-cell"
              >Gem. snelheid</th
            >
            <th
              class="text-left py-3.5 px-5 font-semibold text-gray-600 hidden md:table-cell"
              >Vertrekpunt</th
            >
            <th
              class="text-left py-3.5 px-5 font-semibold text-gray-600 hidden md:table-cell"
              >Toegang</th
            >
          </tr>
        </thead>
        <tbody>
          {
            gesorteerdeRitten.map((rit, i) => (
              <tr
                class={`border-b border-gray-100 last:border-0 ${i % 2 === 0 ? "" : "bg-gray-50/40"}`}
                data-dag={rit.dag}
                data-open={rit.openVoorIedereen ? "true" : "false"}
              >
                <td class="py-3.5 px-5 font-semibold text-gray-900">
                  {dagNamen[rit.dag] ?? rit.dag}
                </td>
                <td class="py-3.5 px-5 font-mono text-gray-700">{rit.uur}</td>
                <td class="py-3.5 px-5">
                  <a
                    href={`/clubs/${rit.clubSlug}`}
                    class="text-primary-600 hover:text-primary-900 font-medium hover:underline"
                  >
                    {rit.clubNaam}
                  </a>
                </td>
                <td class="py-3.5 px-5 hidden sm:table-cell text-gray-600">
                  {rit.type}
                </td>
                <td class="py-3.5 px-5 hidden md:table-cell text-gray-600">
                  {rit.groep ?? "—"}
                </td>
                <td class="py-3.5 px-5 hidden md:table-cell text-gray-600">
                  {formatSpeed(rit.gemiddeldeSnelheid) ?? "—"}
                </td>
                <td class="py-3.5 px-5 hidden md:table-cell text-gray-500">
                  {rit.vertrekpunt}
                </td>
                <td class="py-3.5 px-5 hidden md:table-cell">
                  <span
                    class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${rit.openVoorIedereen ? "bg-primary-100 text-primary-800" : "bg-accent-100 text-accent-800"}`}
                  >
                    {rit.openVoorIedereen
                      ? "Open voor iedereen"
                      : "Enkel leden"}
                  </span>
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>

<script>
  const dagSelect = document.getElementById("filter-dag") as HTMLSelectElement;
  const openCheckbox = document.getElementById(
    "filter-open",
  ) as HTMLInputElement;
  const table = document.getElementById("rides-table");

  function applyFilters() {
    const selectedDag = dagSelect.value;
    const onlyOpen = openCheckbox.checked;

    const rows = table?.querySelectorAll<HTMLTableRowElement>("tbody tr");
    rows?.forEach((row) => {
      const dagMatch = !selectedDag || row.dataset.dag === selectedDag;
      const openMatch = !onlyOpen || row.dataset.open === "true";
      row.style.display = dagMatch && openMatch ? "" : "none";
    });
  }

  const resetButton = document.getElementById(
    "filter-reset",
  ) as HTMLButtonElement;

  function updateResetVisibility() {
    resetButton.classList.toggle(
      "hidden",
      dagSelect.value === "" && !openCheckbox.checked,
    );
  }

  dagSelect.addEventListener("change", () => {
    applyFilters();
    updateResetVisibility();
  });
  openCheckbox.addEventListener("change", () => {
    applyFilters();
    updateResetVisibility();
  });

  resetButton.addEventListener("click", () => {
    dagSelect.value = "";
    openCheckbox.checked = false;
    applyFilters();
    updateResetVisibility();
  });
</script>
