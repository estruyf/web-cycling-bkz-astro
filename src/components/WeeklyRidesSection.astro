---
import type { Club } from "../models";
import { timeSortKey } from "../utils/time";
import SeasonalTime from "./SeasonalTime.astro";
import GenderBadge from "./GenderBadge.astro";

interface Props {
  clubs: Club[];
}

const { clubs } = Astro.props;

const dagNamen: Record<string, string> = {
  Monday: "Maandag",
  Tuesday: "Dinsdag",
  Wednesday: "Woensdag",
  Thursday: "Donderdag",
  Friday: "Vrijdag",
  Saturday: "Zaterdag",
  Sunday: "Zondag",
};

const dayOrder = [
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
  "Sunday",
];

const alleRitten = clubs.flatMap((club) =>
  (club.data.rides ?? []).map((ride) => ({
    clubNaam: club.data.name,
    clubSlug: club.id.replace(/\.md$/, ""),
    locatie: club.data.town,
    gender: ride.gender ?? club.data.gender,
    dag: ride.day,
    uur: ride.time,
    type: ride.type,
    groep: ride.group,
    gemiddeldeSnelheid: ride.averageSpeed,
    vertrekpunt: club.data.meetingPoint,
    openVoorIedereen: ride.openForAll,
  })),
);

const gesorteerdeRitten = alleRitten.sort((a, b) => {
  const d = dayOrder.indexOf(a.dag) - dayOrder.indexOf(b.dag);
  if (d !== 0) return d;
  return timeSortKey(a.uur).localeCompare(timeSortKey(b.uur));
});

const beschikbareDagen = dayOrder.filter((day) =>
  gesorteerdeRitten.some((rit) => rit.dag === day),
);

const beschikbareLocaties = Array.from(
  new Set(gesorteerdeRitten.map((rit) => rit.locatie)),
).sort((a, b) => a.localeCompare(b, "nl"));

function formatSpeed(speed?: number | string): string {
  return speed != null ? `${speed} km/u` : "—";
}
---

<section class="ww-band">
  <div class="ww-wrap">
    <header class="ww-section-head">
      <div>
        <div class="num">01</div>
        <h2>Wekelijkse <em>ritten</em></h2>
        <div class="sub">
          Geplande ritten van alle clubs — filter op dag, gemeente, type
        </div>
      </div>
      <a href="/clubs" class="link" title="Bekijk alle clubs">Alle clubs →</a>
    </header>

    <div class="ww-filters" id="filter-dag-group">
      <button class="ww-chip red on day-filter-btn" data-day="">
        Alle dagen
      </button>
      {
        beschikbareDagen.map((day) => (
          <button class="ww-chip day-filter-btn" data-day={day}>
            {dagNamen[day]}
          </button>
        ))
      }
    </div>

    <div class="ww-filters" style="border-top:0;">
      <select id="filter-town" class="ww-select">
        <option value="">Gemeente</option>
        {
          beschikbareLocaties.map((locatie) => (
            <option value={locatie}>{locatie}</option>
          ))
        }
      </select>

      <select id="filter-gender" class="ww-select">
        <option value="">Groep type</option>
        <option value="mixed">Gemengd</option>
        <option value="men">Mannen</option>
        <option value="women">Vrouwen</option>
      </select>

      <label class="ww-check">
        <input id="filter-open" type="checkbox" />
        Alleen open voor iedereen
      </label>

      <button id="filter-reset" class="ww-chip" style="display:none;">
        Filters wissen
      </button>
    </div>

    <div class="ww-rides" style="margin-top: 24px;">
      <table class="ww-rides-tbl" id="rides-table">
        <thead>
          <tr>
            <th>Dag</th>
            <th>Uur</th>
            <th>Club</th>
            <th>Groep</th>
            <th>Snelheid</th>
            <th>Vertrekpunt</th>
            <th>Type</th>
            <th>Toegang</th>
          </tr>
        </thead>
        <tbody>
          {
            gesorteerdeRitten.map((rit) => (
              <tr
                data-dag={rit.dag}
                data-town={rit.locatie}
                data-gender={rit.gender ?? ""}
                data-open={rit.openVoorIedereen ? "true" : "false"}
              >
                <td data-label="Dag" class="ww-cell-day">
                  {(dagNamen[rit.dag] ?? rit.dag).slice(0, 2)}
                </td>
                <td data-label="Uur" class="ww-cell-time">
                  <SeasonalTime time={rit.uur} />
                </td>
                <td data-label="Club">
                  <a
                    href={`/clubs/${rit.clubSlug}`}
                    class="ww-cell-club"
                    title={`Bekijk ${rit.clubNaam}`}
                  >
                    {rit.clubNaam}
                  </a>
                  <div class="ww-cell-town">{rit.locatie}</div>
                </td>
                <td data-label="Groep">{rit.groep ?? "—"}</td>
                <td data-label="Snelheid">
                  {formatSpeed(rit.gemiddeldeSnelheid)}
                </td>
                <td data-label="Vertrekpunt" class="ww-cell-meta">
                  {rit.vertrekpunt}
                </td>
                <td data-label="Type">
                  <GenderBadge gender={rit.gender} fallback="—" />
                </td>
                <td data-label="Toegang">
                  {rit.openVoorIedereen !== false ? (
                    <span class="ww-badge open">Open</span>
                  ) : (
                    <span class="ww-badge leden">Leden</span>
                  )}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div
      class="ww-filters"
      id="pagination-controls"
      style="justify-content: space-between; border-bottom: 0;"
    >
      <div
        style="font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.1em; color: var(--mute); text-transform: uppercase;"
      >
        Tonen: <span id="page-info">0-0 van 0</span>
      </div>
      <div style="display:flex; gap: 8px;">
        <button id="btn-prev" class="ww-chip">Vorige</button>
        <button id="btn-next" class="ww-chip">Volgende</button>
      </div>
    </div>
  </div>
</section>

<script>
  function initWeeklyRidesSection() {
    const dagBtns =
      document.querySelectorAll<HTMLButtonElement>(".day-filter-btn");
    const townSelect = document.getElementById(
      "filter-town",
    ) as HTMLSelectElement | null;
    const genderSelect = document.getElementById(
      "filter-gender",
    ) as HTMLSelectElement | null;
    const openCheckbox = document.getElementById(
      "filter-open",
    ) as HTMLInputElement | null;
    const table = document.getElementById(
      "rides-table",
    ) as HTMLTableElement | null;
    const pageInfo = document.getElementById("page-info");
    const btnPrev = document.getElementById(
      "btn-prev",
    ) as HTMLButtonElement | null;
    const btnNext = document.getElementById(
      "btn-next",
    ) as HTMLButtonElement | null;
    const resetButton = document.getElementById(
      "filter-reset",
    ) as HTMLButtonElement | null;

    if (
      !dagBtns.length ||
      !townSelect ||
      !genderSelect ||
      !openCheckbox ||
      !table ||
      !resetButton
    ) {
      return;
    }

    const ITEMS_PER_PAGE = 15;
    let selectedDag = "";
    let currentPage = 1;
    let filteredRows: HTMLTableRowElement[] = [];

    function updatePagination() {
      const total = filteredRows.length;
      const totalPages = Math.ceil(total / ITEMS_PER_PAGE) || 1;
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;
      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = Math.min(start + ITEMS_PER_PAGE, total);

      if (pageInfo) {
        pageInfo.textContent =
          total === 0 ? "0 resultaten" : `${start + 1}-${end} van ${total}`;
      }
      if (btnPrev) btnPrev.disabled = currentPage === 1;
      if (btnNext) btnNext.disabled = currentPage === totalPages;

      filteredRows.forEach((row, idx) => {
        row.style.display = idx >= start && idx < end ? "" : "none";
      });
    }

    function applyFilters() {
      currentPage = 1;
      filteredRows = [];
      const selectedTown = townSelect!.value;
      const selectedGender = genderSelect!.value;
      const onlyOpen = openCheckbox!.checked;

      const rows = table!.querySelectorAll<HTMLTableRowElement>("tbody tr");
      rows.forEach((row) => {
        const dagMatch = !selectedDag || row.dataset.dag === selectedDag;
        const townMatch = !selectedTown || row.dataset.town === selectedTown;
        const genderMatch =
          !selectedGender || row.dataset.gender === selectedGender;
        const openMatch = !onlyOpen || row.dataset.open === "true";
        if (dagMatch && townMatch && genderMatch && openMatch) {
          filteredRows.push(row);
        } else {
          row.style.display = "none";
        }
      });
      updatePagination();
    }

    function updateResetVisibility() {
      if (!resetButton) return;
      const show =
        selectedDag !== "" ||
        townSelect!.value !== "" ||
        genderSelect!.value !== "" ||
        openCheckbox!.checked;
      resetButton.style.display = show ? "" : "none";
    }

    function setActiveDay(target: HTMLButtonElement) {
      dagBtns.forEach((b) => b.classList.remove("on"));
      target.classList.add("on");
      selectedDag = target.dataset.day || "";
    }

    dagBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        setActiveDay(btn);
        applyFilters();
        updateResetVisibility();
      });
    });

    townSelect.addEventListener("change", () => {
      applyFilters();
      updateResetVisibility();
    });
    genderSelect.addEventListener("change", () => {
      applyFilters();
      updateResetVisibility();
    });
    openCheckbox.addEventListener("change", () => {
      applyFilters();
      updateResetVisibility();
    });

    resetButton.addEventListener("click", () => {
      const allBtn = Array.from(dagBtns).find((b) => b.dataset.day === "");
      if (allBtn) setActiveDay(allBtn);
      townSelect!.value = "";
      genderSelect!.value = "";
      openCheckbox!.checked = false;
      applyFilters();
      updateResetVisibility();
    });

    btnPrev?.addEventListener("click", () => {
      if (currentPage > 1) {
        currentPage--;
        updatePagination();
        const top = document.getElementById("filter-dag-group")?.offsetTop || 0;
        window.scrollTo({ top: top - 100, behavior: "smooth" });
      }
    });
    btnNext?.addEventListener("click", () => {
      const totalPages = Math.ceil(filteredRows.length / ITEMS_PER_PAGE) || 1;
      if (currentPage < totalPages) {
        currentPage++;
        updatePagination();
        const top = document.getElementById("filter-dag-group")?.offsetTop || 0;
        window.scrollTo({ top: top - 100, behavior: "smooth" });
      }
    });

    applyFilters();
  }

  document.addEventListener("astro:page-load", initWeeklyRidesSection);
</script>
