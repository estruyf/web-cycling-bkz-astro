---
interface Props {
  slug: string;
}

const { slug = "home" } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="ww-footer">
  <div class="ww-wrap">
    <div class="ww-foot-grid">
      <div class="about">
        <div class="ww-brand" style="color: var(--chalk);">
          <svg
            width="44"
            height="18"
            aria-hidden="true"
            style="color: var(--chalk);"
          >
            <use href="#ww-bike"></use>
          </svg>
          <div>
            <div class="ww-brand-txt" style="color: var(--chalk);">
              Wieler<em>Waas</em>
            </div>
            <div class="ww-brand-sub">Wielrennen in het Waasland</div>
          </div>
        </div>
        <p>
          Jouw gids voor wielerclubs en evenementen in het Waasland. Voor en
          door fietsers. Samen op de weg.
        </p>
      </div>

      <div>
        <h4>Snelle links</h4>
        <ul>
          <li><a href="/" title="Home">Home</a></li>
          <li><a href="/clubs" title="Clubs">Clubs</a></li>
          <li><a href="/evenementen" title="Evenementen">Evenementen</a></li>
          <li><a href="/sponsors" title="Sponsors">Sponsors</a></li>
          <li><a href="/over-ons" title="Over ons">Over ons</a></li>
        </ul>
      </div>

      <div>
        <h4>Meedoen</h4>
        <ul>
          <li>
            <a href="/add-club" title="Voeg je club toe">Voeg je club toe</a>
          </li>
          <li>
            <a href="/add-event" title="Voeg je evenement toe"
              >Voeg je evenement toe</a
            >
          </li>
          <li><a href="/sponsors" title="Partner worden">Partner worden</a></li>
          <li>
            <a href="mailto:elio@struyfconsulting.be" title="Contact">Contact</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h4>Volg ons</h4>
        <ul>
          <li>
            <a
              href="https://www.strava.com/clubs/2078214"
              title="WielerWaas op Strava"
              target="_blank"
              rel="noopener noreferrer"
              >Strava</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div class="ww-foot-bottom">
      <span
        >&copy; {year} WielerWaas · Gebouwd door <a
          href="https://eliostruyf.com"
          title="Bezoek de website van Elio Struyf">Elio Struyf</a
        ></span
      >
      <a
        href="https://visitorbadge.io/status?path=https%3A%2F%2Fwielerwaas.be"
        title="Bezoekerstelling"
        aria-label="Bezoekerstelling"
      >
        <img
          src={`https://api.visitorbadge.io/api/combined?path=https%3A%2F%2Fwielerwaas.be&label=Bezoekers&labelColor=%23110c09&countColor=%23110c09&style=flat-square&labelStyle=upper&slug=${slug}`}
          alt="Bezoekersbadge"
        />
      </a>
    </div>
  </div>
</footer>
