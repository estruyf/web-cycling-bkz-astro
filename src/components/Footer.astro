---
import Logo from "./Logo.astro";

interface Props {
  slug: string;
}

const { slug = "home" } = Astro.props;
---

<footer class="bg-primary-900 text-primary-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="flex items-center gap-3 mb-3">
          <Logo className="w-8 h-8 text-white" />
          <span class="font-bold text-white">WielerWaas</span>
        </div>
        <p class="text-sm text-primary-300 leading-relaxed">
          Jouw gids voor wielerclubs en evenementen in het Waasland.
        </p>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Snelle links</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/" class="hover:text-white transition-colors">Home</a>
          </li>
          <li>
            <a href="/clubs" class="hover:text-white transition-colors">Clubs</a
            >
          </li>
          <li>
            <a href="/sponsors" class="hover:text-white transition-colors"
              >Sponsors</a
            >
          </li>
          <li>
            <a href="/over-ons" class="hover:text-white transition-colors"
              >Over ons</a
            >
          </li>
          <li>
            <a href="/add-club" class="hover:text-white transition-colors"
              >Voeg je club toe</a
            >
          </li>
          <li>
            <a href="/add-event" class="hover:text-white transition-colors"
              >Voeg je evenement toe</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Community</h4>
        <ul class="space-y-2 text-sm">
          <li class="text-primary-300">Wielrennen in het Waasland</li>
          <li class="text-primary-300">Voor en door fietsers</li>
          <li class="text-primary-300">Samen op de weg</li>
        </ul>
      </div>
    </div>

    <div
      class="border-t border-primary-800 mt-8 pt-6 text-xs text-primary-400 text-center flex flex-col items-center gap-2"
    >
      &copy; {new Date().getFullYear()} WielerWaas

      <a href="https://visitorbadge.io/status?path=https%3A%2F%2Fwielerwaas.be">
        <img
          src={`https://api.visitorbadge.io/api/combined?path=https%3A%2F%2Fwielerwaas.be&label=Bezoekers&labelColor=%23023047&countColor=%23023047&style=flat-square&labelStyle=upper&slug=${slug}`}
        />
      </a>
    </div>
  </div>
</footer>
