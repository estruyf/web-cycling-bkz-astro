---
import { getCollection } from "astro:content";

const sponsors = (await getCollection("sponsors"))
  .filter((s) => s.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---

{
  sponsors.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-2">
        Onze sponsors
      </h2>
      <p class="text-gray-500 text-sm text-center mb-10">
        Steun voor het lokale wielrennen in het Waasland
      </p>

      <div class="flex flex-wrap justify-center gap-6">
        {sponsors.map((s) => (
          <a
            href={s.data.website || "#"}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center bg-white border border-gray-200 rounded-xl px-8 py-5 hover:border-gray-400 transition-colors min-w-40 font-semibold text-gray-800"
          >
            {s.data.logo ? (
              <img
                src={s.data.logo}
                alt={s.data.name}
                class="h-10 object-contain"
              />
            ) : (
              s.data.name
            )}
          </a>
        ))}
      </div>
    </section>
  )
}
