---
import { getCollection } from "astro:content";

const sponsors = (await getCollection("sponsors"))
  .filter((s) => s.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---

{
  sponsors.length > 0 && (
    <section class="ww-sponsors">
      <div class="ww-wrap">
        <span class="label">Met steun van</span>
        {sponsors.map((s) => (
          <a
            href={s.data.website || "#"}
            title={s.data.name || ""}
            target="_blank"
            rel="noopener noreferrer"
            class="ww-sponsor-logo"
          >
            {s.data.logo ? (
              <img src={s.data.logo} alt={s.data.name} />
            ) : (
              <span>{s.data.name}</span>
            )}
          </a>
        ))}
      </div>
    </section>
  )
}
