---
import type { SeasonalTime as SeasonalTimeType } from "../models/Club";
import SeasonalTime from "./SeasonalTime.astro";

interface Ride {
  day: string;
  time: string | SeasonalTimeType[];
  type: string;
  notes?: string;
}

interface Props {
  name: string;
  slug: string;
  town: string;
  shortDescription?: string;
  meetingPoint?: string;
  rides?: Ride[];
  logo?: string;
  gender?: "women" | "men" | "mixed";
}

const { name, slug, town, shortDescription, meetingPoint, rides, logo } =
  Astro.props;

const dayOrder = [
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
  "Sunday",
];
const sortedRides = [...(rides ?? [])].sort(
  (a, b) => dayOrder.indexOf(a.day) - dayOrder.indexOf(b.day),
);

const displayedRides = sortedRides.filter((ride, index, all) => {
  const key = (r: Ride) =>
    `${r.day}|${typeof r.time === "string" ? r.time : JSON.stringify(r.time)}`;
  return all.findIndex((c) => key(c) === key(ride)) === index;
});

const dagAfkorting: Record<string, string> = {
  Monday: "Ma",
  Tuesday: "Di",
  Wednesday: "Wo",
  Thursday: "Do",
  Friday: "Vr",
  Saturday: "Za",
  Sunday: "Zo",
};
---

<a href={`/clubs/${slug}`} class="ww-club" title={`Bekijk ${name}`}>
  <div class="ww-club-top"></div>
  <div class="ww-club-body">
    <div class="ww-club-head">
      <div class="ww-club-mono">
        {logo ? <img src={logo} alt={name} /> : <span>{name.charAt(0)}</span>}
      </div>
      <div style="min-width:0; flex:1;">
        <h3>{name}</h3>
        <div class="town">{town}</div>
      </div>
    </div>

    {shortDescription && <p class="desc">{shortDescription}</p>}

    {meetingPoint && <div class="meet">↳ {meetingPoint}</div>}

    {
      displayedRides.length > 0 && (
        <div class="rides-pills">
          {displayedRides.map((ride) => (
            <span class="ww-ride-pill">
              <b>{dagAfkorting[ride.day] ?? ride.day.slice(0, 2)}</b>
              <SeasonalTime time={ride.time} />
            </span>
          ))}
        </div>
      )
    }
  </div>
</a>
