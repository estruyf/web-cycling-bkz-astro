---
import { getGenderBadge, type Gender } from "../utils/gender";

interface Props {
  gender?: Gender;
  className?: string;
  fallback?: string;
}

const { gender, className = "", fallback } = Astro.props;
const badge = getGenderBadge(gender);
---

{
  badge ? (
    <span
      class:list={[
        "inline-flex items-center gap-1 text-xs font-semibold px-3 py-1 rounded-full",
        badge.classes,
        className,
      ]}
      aria-label={badge.ariaLabel}
    >
      {badge.label}
    </span>
  ) : (
    (fallback ?? null)
  )
}
