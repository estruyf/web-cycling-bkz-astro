---
import { getGenderBadge, type Gender } from "../utils/gender";

interface Props {
  gender?: Gender;
  className?: string;
  fallback?: string;
}

const { gender, className = "", fallback } = Astro.props;
const badge = getGenderBadge(gender);
---

{
  badge ? (
    <span
      class:list={[badge.classes, className]}
      aria-label={badge.ariaLabel}
    >
      {badge.label}
    </span>
  ) : (
    (fallback ?? null)
  )
}
