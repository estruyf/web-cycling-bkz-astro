---
interface Props {
  name: string;
  date?: Date;
  startDate?: Date;
  endDate?: Date;
  frequency?: "once" | "weekly" | "monthly";
  time?: string;
  organizer: string;
  location: string;
  website?: string;
  slug: string;
}

const {
  name,
  date,
  startDate,
  endDate,
  frequency = "once",
  time,
  organizer,
  location,
  website,
  slug,
} = Astro.props;

const eventSlug = slug.replace(/\.md$/, "");
const eventDetailsUrl = `/evenementen/${eventSlug}`;

const maandNamen = [
  "jan",
  "feb",
  "mrt",
  "apr",
  "mei",
  "jun",
  "jul",
  "aug",
  "sep",
  "okt",
  "nov",
  "dec",
];

const dagNamen = [
  "zondag",
  "maandag",
  "dinsdag",
  "woensdag",
  "donderdag",
  "vrijdag",
  "zaterdag",
];

const primaryDate = startDate ?? date;
const finalDate = endDate ?? startDate ?? date;

if (!primaryDate) {
  throw new Error(`EventCard vereist minstens een datum voor event: ${slug}`);
}

const dag = primaryDate.getUTCDate();
const maand = maandNamen[primaryDate.getUTCMonth()];
const dagNaam = dagNamen[primaryDate.getUTCDay()];

const frequencyLabels = {
  once: "Eenmalig",
  weekly: "Wekelijks",
  monthly: "Maandelijks",
};

const formatDate = (inputDate: Date) => {
  const day = inputDate.getUTCDate().toString().padStart(2, "0");
  const month = (inputDate.getUTCMonth() + 1).toString().padStart(2, "0");
  const year = inputDate.getUTCFullYear();
  return `${day}/${month}/${year}`;
};

const hasDateRange =
  !!finalDate && primaryDate.getTime() !== finalDate.getTime();
---

<div
  class="flex gap-4 bg-white rounded-xl border border-gray-100 shadow-sm p-5 hover:border-primary-200 transition-colors"
>
  <div class="flex-shrink-0 w-16 text-center">
    <div class="bg-primary-50 rounded-lg py-2 px-3">
      <span class="block text-2xl font-bold text-primary-700 leading-tight"
        >{dag}</span
      >
      <span class="block text-xs font-semibold text-primary-500 uppercase"
        >{maand}</span
      >
    </div>
  </div>

  <div class="flex-1 min-w-0">
    <div class="flex flex-wrap items-center gap-2">
      <h3 class="font-bold text-gray-900 text-base truncate">
        <a
          href={eventDetailsUrl}
          class="hover:text-primary-700 transition-colors"
        >
          {name}
        </a>
      </h3>
      {
        frequency !== "once" && (
          <span class="inline-flex items-center rounded-full bg-primary-50 px-2 py-0.5 text-xs font-semibold text-primary-700">
            {frequencyLabels[frequency]}
          </span>
        )
      }
    </div>
    <div
      class="flex flex-wrap items-center gap-x-4 gap-y-1 mt-1.5 text-sm text-gray-500"
    >
      <span class="inline-flex items-center gap-1">
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
          ></path>
        </svg>
        <span class="capitalize">{dagNaam}</span>
      </span>
      {
        hasDateRange && finalDate && (
          <span class="inline-flex items-center gap-1">
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
            {formatDate(primaryDate)} - {formatDate(finalDate)}
          </span>
        )
      }
      {
        time && (
          <span class="inline-flex items-center gap-1">
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            {time}
          </span>
        )
      }
      <span class="inline-flex items-center gap-1">
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
          ></path>
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        {location}
      </span>
      <span class="inline-flex items-center gap-1">
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
          ></path>
        </svg>
        {organizer}
      </span>
    </div>
    <div class="flex flex-wrap items-center gap-3 mt-2">
      <a
        href={eventDetailsUrl}
        class="inline-flex items-center gap-1 text-sm text-primary-600 hover:text-primary-800 font-medium"
      >
        Bekijk details
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </a>
      {
        website && (
          <a
            href={website}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 font-medium"
          >
            Eventwebsite
            <svg
              class="w-3.5 h-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
              />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</div>
