---
interface Props {
  name: string;
  date?: Date;
  startDate?: Date;
  endDate?: Date;
  frequency?: "once" | "weekly" | "monthly";
  time?: string;
  organizer: string;
  location: string;
  website?: string;
  slug: string;
}

const {
  name,
  date,
  startDate,
  endDate,
  frequency = "once",
  time,
  organizer,
  location,
  website,
  slug,
} = Astro.props;

const eventSlug = slug.replace(/\.md$/, "");
const eventDetailsUrl = `/evenementen/${eventSlug}`;

const maandNamen = [
  "jan",
  "feb",
  "mrt",
  "apr",
  "mei",
  "jun",
  "jul",
  "aug",
  "sep",
  "okt",
  "nov",
  "dec",
];
const dagNamen = [
  "zondag",
  "maandag",
  "dinsdag",
  "woensdag",
  "donderdag",
  "vrijdag",
  "zaterdag",
];

const primaryDate = startDate ?? date;
const finalDate = endDate ?? startDate ?? date;

if (!primaryDate) {
  throw new Error(`EventCard vereist minstens een datum voor event: ${slug}`);
}

const dag = primaryDate.getUTCDate();
const maand = maandNamen[primaryDate.getUTCMonth()];
const dagNaam = dagNamen[primaryDate.getUTCDay()];

const frequencyLabels = {
  once: "Eenmalig",
  weekly: "Wekelijks",
  monthly: "Maandelijks",
};

const formatDate = (d: Date) => {
  const day = d.getUTCDate().toString().padStart(2, "0");
  const month = (d.getUTCMonth() + 1).toString().padStart(2, "0");
  return `${day}/${month}`;
};

const hasDateRange =
  !!finalDate && primaryDate.getTime() !== finalDate.getTime();
---

<article class="ww-event">
  {
    frequency !== "once" && (
      <span class="ww-event-freq">{frequencyLabels[frequency]}</span>
    )
  }
  <div class={`ww-date-block ${frequency === "once" ? "accent" : ""}`}>
    <div class="d">{dag}</div>
    <div class="m">{maand}</div>
  </div>
  <div class="ww-event-body">
    <h3>
      <a href={eventDetailsUrl} title={`Bekijk details van ${name}`}>{name}</a>
    </h3>
    <div class="meta">
      <span class="cap">{dagNaam}</span>
      {
        hasDateRange && finalDate && (
          <span>
            {formatDate(primaryDate)}–{formatDate(finalDate)}
          </span>
        )
      }
      {time && <span>{time}</span>}
    </div>
    <div class="meta">
      <span>📍 {location}</span>
      <span>👥 {organizer}</span>
    </div>
    <div class="links">
      <a href={eventDetailsUrl} title={`Bekijk details van ${name}`}>Bekijk details →</a>
      {
        website && (
          <a
            href={website}
            target="_blank"
            rel="noopener noreferrer"
            class="ext"
            title={`Bezoek de eventwebsite van ${name}`}
          >
            Eventwebsite ↗
          </a>
        )
      }
    </div>
  </div>
</article>
