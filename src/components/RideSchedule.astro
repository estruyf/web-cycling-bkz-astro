---
interface Ride {
  day: string;
  time: string;
  type: string;
  group?: string;
  averageSpeed?: number | string;
  notes?: string;
  openForAll?: boolean;
}

interface Props {
  rides: Ride[];
}

const { rides } = Astro.props;

const dayOrder = [
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
  "Sunday",
];
const sorted = [...rides].sort(
  (a, b) => dayOrder.indexOf(a.day) - dayOrder.indexOf(b.day),
);

const dagNamen: Record<string, string> = {
  Monday: "Maandag",
  Tuesday: "Dinsdag",
  Wednesday: "Woensdag",
  Thursday: "Donderdag",
  Friday: "Vrijdag",
  Saturday: "Zaterdag",
  Sunday: "Zondag",
};

const typeColors: Record<string, string> = {
  Groepstraining: "bg-primary-100 text-primary-800",
  "TTC Rit": "bg-primary-200 text-primary-900",
  "TTC Koffierit": "bg-accent-100 text-accent-800",
};

function getTypeColor(type: string) {
  return typeColors[type] ?? "bg-gray-100 text-gray-700";
}

function formatSpeed(speed?: number | string): string | undefined {
  return speed != null ? `${speed} km/u` : undefined;
}
---

<div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200">
        <th class="text-left py-3 px-4 font-semibold text-gray-600 w-32">Dag</th
        >
        <th class="text-left py-3 px-4 font-semibold text-gray-600 w-24">Uur</th
        >
        <th class="text-left py-3 px-4 font-semibold text-gray-600">Type rit</th
        >
        <th
          class="text-left py-3 px-4 font-semibold text-gray-600 hidden sm:table-cell"
          >Groep</th
        >
        <th
          class="text-left py-3 px-4 font-semibold text-gray-600 hidden sm:table-cell"
          >Gem. snelheid</th
        >
        <th
          class="text-left py-3 px-4 font-semibold text-gray-600 hidden sm:table-cell"
          >Opmerkingen</th
        >
        <th class="text-left py-3 px-4 font-semibold text-gray-600 w-36"
          >Toegang</th
        >
      </tr>
    </thead>
    <tbody>
      {
        sorted.map((ride, i) => (
          <tr
            class={`border-b border-gray-100 ${i % 2 === 0 ? "bg-white" : "bg-gray-50/50"}`}
          >
            <td class="py-3 px-4 font-medium text-gray-900">
              {dagNamen[ride.day] ?? ride.day}
            </td>
            <td class="py-3 px-4 text-gray-700 font-mono">{ride.time}</td>
            <td class="py-3 px-4">
              <span
                class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${getTypeColor(ride.type)}`}
              >
                {ride.type}
              </span>
            </td>
            <td class="py-3 px-4 text-gray-600 hidden sm:table-cell">
              {ride.group ?? "—"}
            </td>
            <td class="py-3 px-4 text-gray-600 hidden sm:table-cell">
              {formatSpeed(ride.averageSpeed) ?? "—"}
            </td>
            <td class="py-3 px-4 text-gray-500 hidden sm:table-cell">
              {ride.notes ?? "—"}
            </td>
            <td class="py-3 px-4">
              {ride.openForAll !== false ? (
                <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-primary-100 text-primary-800 whitespace-nowrap">
                  Open
                </span>
              ) : (
                <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent-100 text-accent-800 whitespace-nowrap">
                  Leden
                </span>
              )}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
