---
import type { SeasonalTime as SeasonalTimeType } from "../models/Club";
import type { Gender } from "../utils/gender";
import SeasonalTime from "./SeasonalTime.astro";
import GenderBadge from "./GenderBadge.astro";

interface Ride {
  day: string;
  time: string | SeasonalTimeType[];
  type: string;
  group?: string;
  averageSpeed?: number | string;
  notes?: string;
  openForAll?: boolean;
  gender?: Gender;
}

interface Props {
  rides: Ride[];
}

const { rides } = Astro.props;

const dayOrder = [
  "Monday", "Tuesday", "Wednesday", "Thursday",
  "Friday", "Saturday", "Sunday",
];
const sorted = [...rides].sort(
  (a, b) => dayOrder.indexOf(a.day) - dayOrder.indexOf(b.day),
);

const dagNamen: Record<string, string> = {
  Monday: "Maandag",
  Tuesday: "Dinsdag",
  Wednesday: "Woensdag",
  Thursday: "Donderdag",
  Friday: "Vrijdag",
  Saturday: "Zaterdag",
  Sunday: "Zondag",
};

function formatSpeed(speed?: number | string): string {
  return speed != null ? `${speed} km/u` : "—";
}
---

<div class="ww-rides">
  <table class="ww-rides-tbl">
    <thead>
      <tr>
        <th>Dag</th>
        <th>Uur</th>
        <th>Type rit</th>
        <th>Groep</th>
        <th>Gem. snelheid</th>
        <th>Opmerkingen</th>
        <th>Groep type</th>
        <th>Toegang</th>
      </tr>
    </thead>
    <tbody>
      {
        sorted.map((ride) => (
          <tr>
            <td data-label="Dag" class="ww-cell-day">
              {dagNamen[ride.day] ?? ride.day}
            </td>
            <td data-label="Uur" class="ww-cell-time">
              <SeasonalTime time={ride.time} />
            </td>
            <td data-label="Type rit">{ride.type}</td>
            <td data-label="Groep">{ride.group ?? "—"}</td>
            <td data-label="Gem. snelheid">{formatSpeed(ride.averageSpeed)}</td>
            <td data-label="Opmerkingen">{ride.notes ?? "—"}</td>
            <td data-label="Groep type">
              <GenderBadge gender={ride.gender} fallback="—" />
            </td>
            <td data-label="Toegang">
              {ride.openForAll !== false ? (
                <span class="ww-badge open">Open</span>
              ) : (
                <span class="ww-badge leden">Leden</span>
              )}
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
