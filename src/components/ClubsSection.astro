---
import type { CollectionEntry } from "astro:content";
import ClubCard from "./ClubCard.astro";

interface Props {
  clubs: CollectionEntry<"clubs">[];
  totalCount?: number;
}

const { clubs, totalCount } = Astro.props;
const displayCount = totalCount ?? clubs.length;
---

<section class="bg-white py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Clubs</h2>
        <p class="text-gray-500 text-sm mt-1">
          {displayCount} club{displayCount !== 1 ? "s" : ""} in de regio
        </p>
      </div>
      <a
        href="/clubs"
        class="text-primary-500 hover:text-primary-600 text-sm font-medium flex items-center gap-1"
      >
        Bekijk alle
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        clubs.map((club) => (
          <ClubCard
            name={club.data.name}
            slug={club.id.replace(/\.md$/, "")}
            town={club.data.town}
            shortDescription={club.data.shortDescription}
            meetingPoint={club.data.meetingPoint}
            rides={club.data.rides}
            logo={club.data.logo}
          />
        ))
      }
    </div>
  </div>
</section>
