---
import type { CollectionEntry } from "astro:content";
import ClubCard from "./ClubCard.astro";

interface Props {
  clubs: CollectionEntry<"clubs">[];
  totalCount?: number;
}

const { clubs, totalCount } = Astro.props;
const displayCount = totalCount ?? clubs.length;
---

<section class="ww-band">
  <div class="ww-wrap">
    <header class="ww-section-head">
      <div>
        <div class="num">04</div>
        <h2>Clubs in <em>het waasland</em></h2>
        <div class="sub">
          {displayCount} club{displayCount !== 1 ? "s" : ""} in de regio
        </div>
      </div>
      <a href="/clubs" class="link" title="Bekijk alle clubs">Bekijk alle →</a>
    </header>

    <div class="ww-clubs-grid">
      {
        clubs.map((club) => (
          <ClubCard
            name={club.data.name}
            slug={club.id.replace(/\.md$/, "")}
            town={club.data.town}
            shortDescription={club.data.shortDescription}
            meetingPoint={club.data.meetingPoint}
            rides={club.data.rides}
            logo={club.data.logo}
          />
        ))
      }
    </div>
  </div>
</section>
