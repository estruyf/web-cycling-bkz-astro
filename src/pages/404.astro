---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Pagina niet gevonden - WielerWaas" description="De pagina die je zoekt bestaat niet of is verplaatst." hideSponsors={true}>
  <main class="flex items-center justify-center min-h-[70vh] px-4 py-16">
    <div class="text-center max-w-md">
      <p class="text-8xl font-extrabold text-primary-500 mb-4">404</p>
      <h1 class="text-2xl font-bold text-primary-900 mb-2">
        Oeps! Deze pagina bestaat niet.
      </h1>
      <p class="text-gray-500 mb-8">
        De pagina die je zoekt is verplaatst of bestaat niet meer.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-block px-6 py-3 bg-accent-500 hover:bg-accent-600 text-primary-900 font-semibold rounded-xl shadow-sm transition-colors"
        >
          Terug naar home
        </a>
        <a
          href="/clubs"
          class="inline-block px-6 py-3 bg-primary-500 hover:bg-primary-600 text-white font-semibold rounded-xl shadow-sm transition-colors"
        >
          Bekijk alle clubs
        </a>
      </div>
    </div>
  </main>
</Layout>
