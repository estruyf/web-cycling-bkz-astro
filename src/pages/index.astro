---
import Layout from "../layouts/Layout.astro";
import ClubCard from "../components/ClubCard.astro";
import EventCard from "../components/EventCard.astro";
import AddClubCta from "../components/AddClubCta.astro";
import { getCollection } from "astro:content";

const clubs = (await getCollection("clubs")).filter((c) => c.data.active);
const sponsors = (await getCollection("sponsors")).filter((s) => s.data.active);

const now = new Date();
const upcomingEvents = (await getCollection("events"))
  .filter((e) => e.data.active && new Date(e.data.date) >= new Date(now.getFullYear(), now.getMonth(), now.getDate()))
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .slice(0, 3);

const dayOrder = [
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
  "Sunday",
];

const dagNamen: Record<string, string> = {
  Monday: "Maandag",
  Tuesday: "Dinsdag",
  Wednesday: "Woensdag",
  Thursday: "Donderdag",
  Friday: "Vrijdag",
  Saturday: "Zaterdag",
  Sunday: "Zondag",
};

interface WeekritOverzicht {
  clubNaam: string;
  clubSlug: string;
  dag: string;
  uur: string;
  type: string;
  vertrekpunt: string;
  openVoorIedereen: boolean;
}

const alleRitten: WeekritOverzicht[] = clubs.flatMap((club) =>
  club.data.rides.map((ride) => ({
    clubNaam: club.data.name,
    clubSlug: club.id.replace(/\.md$/, ""),
    dag: ride.day,
    uur: ride.time,
    type: ride.type,
    vertrekpunt: club.data.meetingPoint,
    openVoorIedereen: ride.openForAll,
  })),
);

const gesorteerdeRitten = alleRitten.sort((a, b) => {
  const dagVerschil = dayOrder.indexOf(a.dag) - dayOrder.indexOf(b.dag);
  if (dagVerschil !== 0) return dagVerschil;
  return a.uur.localeCompare(b.uur);
});

const goldSponsors = sponsors
  .filter((s) => s.data.tier === "gold")
  .sort((a, b) => a.data.order - b.data.order);
const silverSponsors = sponsors
  .filter((s) => s.data.tier === "silver")
  .sort((a, b) => a.data.order - b.data.order);
const bronzeSponsors = sponsors
  .filter((s) => s.data.tier === "bronze")
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Cycling BKZ — Beveren, Kruibeke & Zwijndrecht"
  description="Ontdek wielrenclubs in Beveren, Kruibeke en Zwijndrecht. Bekijk wanneer en waar ze vertrekken."
>
  <section
    class="relative bg-gradient-to-br from-primary-900 via-primary-800 to-primary-700 text-white overflow-hidden"
  >
    <div class="absolute inset-0 opacity-10">
      <img
        src="https://images.unsplash.com/photo-1452573992436-6d508f200b30?q=80&w=1600&auto=format&fit=crop"
        alt=""
        class="w-full h-full object-cover"
      />
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-2xl">
        <div
          class="inline-flex items-center gap-2 bg-primary-500/20 border border-primary-400/30 rounded-full px-4 py-1.5 text-primary-200 text-sm font-medium mb-6"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path
              fill-rule="evenodd"
              d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
              clip-rule="evenodd"></path>
          </svg>
          Beveren · Kruibeke · Zwijndrecht
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-6">
          Vind jouw groep,<br />
          <span class="text-accent-500">trap mee.</span>
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-8">
          Ontdek de wielrenclubs in onze regio. Bekijk wanneer en waar ze
          vertrekken, en sluit je aan bij een groep die bij jou past.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/clubs"
            class="inline-flex items-center gap-2 bg-accent-600 hover:bg-accent-500 text-white font-semibold px-6 py-3 rounded-xl transition-colors"
          >
            Bekijk alle clubs
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
          <a
            href="/add-club"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-colors"
          >
            Voeg je club toe
           </a>
        </div>
      </div>
    </div>

    <div
      class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-gray-50 to-transparent"
    >
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Wekelijkse ritten</h2>
        <p class="text-gray-500 text-sm mt-1">
          Alle geplande ritten van alle clubs
        </p>
      </div>
      <a
        href="/clubs"
        class="text-primary-500 hover:text-primary-600 text-sm font-medium flex items-center gap-1"
      >
        Alle clubs
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </a>
    </div>

    <div
      class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden"
    >
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="text-left py-3.5 px-5 font-semibold text-gray-600"
                >Dag</th
              >
              <th class="text-left py-3.5 px-5 font-semibold text-gray-600"
                >Uur</th
              >
              <th class="text-left py-3.5 px-5 font-semibold text-gray-600"
                >Club</th
              >
              <th
                class="text-left py-3.5 px-5 font-semibold text-gray-600 hidden sm:table-cell"
                >Type rit</th
              >
              <th
                class="text-left py-3.5 px-5 font-semibold text-gray-600 hidden md:table-cell"
                >Vertrekpunt</th
              >
              <th
                class="text-left py-3.5 px-5 font-semibold text-gray-600 hidden md:table-cell"
                >Toegang</th
              >
            </tr>
          </thead>
          <tbody>
            {
              gesorteerdeRitten.map((rit, i) => (
                <tr
                  class={`border-b border-gray-100 last:border-0 ${i % 2 === 0 ? "" : "bg-gray-50/40"}`}
                >
                  <td class="py-3.5 px-5 font-semibold text-gray-900">
                    {dagNamen[rit.dag] ?? rit.dag}
                  </td>
                  <td class="py-3.5 px-5 font-mono text-gray-700">
                    {rit.uur}
                  </td>
                  <td class="py-3.5 px-5">
                    <a
                      href={`/clubs/${rit.clubSlug}`}
                      class="text-primary-600 hover:text-primary-900 font-medium hover:underline"
                    >
                      {rit.clubNaam}
                    </a>
                  </td>
                  <td class="py-3.5 px-5 hidden sm:table-cell text-gray-600">
                    {rit.type}
                  </td>
                  <td class="py-3.5 px-5 hidden md:table-cell text-gray-500">
                    {rit.vertrekpunt}
                  </td>
                  <td class="py-3.5 px-5 hidden md:table-cell">
                    <span class={`inline-block px-2.5 py-0.5 rounded-full text-xs font-medium ${rit.openVoorIedereen ? "bg-primary-100 text-primary-800" : "bg-accent-100 text-accent-800"}`}>
                      {rit.openVoorIedereen ? "Open voor iedereen" : "Enkel leden"}
                    </span>
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {upcomingEvents.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Aankomende evenementen</h2>
          <p class="text-gray-500 text-sm mt-1">
            Ritten en evenementen van clubs in de regio
          </p>
        </div>
        <a
          href="/evenementen"
          class="text-primary-500 hover:text-primary-600 text-sm font-medium flex items-center gap-1"
        >
          Alle evenementen
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {upcomingEvents.map((event) => (
          <EventCard
            name={event.data.name}
            date={event.data.date}
            time={event.data.time}
            organizer={event.data.organizer}
            location={event.data.location}
            website={event.data.website}
            slug={event.id}
          />
        ))}
      </div>
    </section>
  )}

  <section class="bg-white border-y border-gray-100 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-2xl font-bold text-gray-900">Actieve clubs</h2>
          <p class="text-gray-500 text-sm mt-1">
            {clubs.length} club{clubs.length !== 1 ? "s" : ""} in de regio
          </p>
        </div>
        <a
          href="/clubs"
          class="text-primary-500 hover:text-primary-600 text-sm font-medium flex items-center gap-1"
        >
          Bekijk alle
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          clubs.map((club) => (
            <ClubCard
              name={club.data.name}
              slug={club.id.replace(/\.md$/, "")}
              town={club.data.town}
              shortDescription={club.data.shortDescription}
              meetingPoint={club.data.meetingPoint}
              rides={club.data.rides}
              logo={club.data.logo}
            />
          ))
        }
      </div>
    </div>
  </section>

  {
    sponsors.length > 0 && (
      <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <h2 class="text-2xl font-bold text-gray-900 text-center mb-2">
          Onze sponsors
        </h2>
        <p class="text-gray-500 text-sm text-center mb-10">
          Steun voor het lokale wielrennen in Beveren, Kruibeke &amp; Zwijndrecht
        </p>

        {goldSponsors.length > 0 && (
          <div class="mb-8">
            <p class="text-xs uppercase tracking-widest text-accent-600 font-semibold text-center mb-5">
              Goud
            </p>
            <div class="flex flex-wrap justify-center gap-6">
              {goldSponsors.map((s) => (
                <a
                  href={s.data.website || "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center bg-white border-2 border-accent-300 rounded-xl px-8 py-5 hover:border-accent-500 transition-colors min-w-40 font-semibold text-gray-800"
                >
                  {s.data.logo ? (
                    <img
                      src={s.data.logo}
                      alt={s.data.name}
                      class="h-10 object-contain"
                    />
                  ) : (
                    s.data.name
                  )}
                </a>
              ))}
            </div>
          </div>
        )}

        {silverSponsors.length > 0 && (
          <div class="mb-8">
            <p class="text-xs uppercase tracking-widest text-gray-500 font-semibold text-center mb-5">
              Zilver
            </p>
            <div class="flex flex-wrap justify-center gap-5">
              {silverSponsors.map((s) => (
                <a
                  href={s.data.website || "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center bg-white border border-gray-200 rounded-xl px-7 py-4 hover:border-gray-400 transition-colors min-w-36 font-medium text-gray-700"
                >
                  {s.data.logo ? (
                    <img
                      src={s.data.logo}
                      alt={s.data.name}
                      class="h-8 object-contain"
                    />
                  ) : (
                    s.data.name
                  )}
                </a>
              ))}
            </div>
          </div>
        )}

        {bronzeSponsors.length > 0 && (
          <div>
            <p class="text-xs uppercase tracking-widest text-accent-800 font-semibold text-center mb-5">
              Brons
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              {bronzeSponsors.map((s) => (
                <a
                  href={s.data.website || "#"}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center bg-white border border-gray-100 rounded-xl px-6 py-3 hover:border-gray-300 transition-colors font-medium text-gray-600"
                >
                  {s.data.logo ? (
                    <img
                      src={s.data.logo}
                      alt={s.data.name}
                      class="h-6 object-contain"
                    />
                  ) : (
                    s.data.name
                  )}
                </a>
              ))}
            </div>
          </div>
        )}
      </section>
    )
  }

  <AddClubCta />
</Layout>
