---
import Layout from "../layouts/Layout.astro";
import AddClubCta from "../components/AddClubCta.astro";
import WeeklyRidesSection from "../components/WeeklyRidesSection.astro";
import UpcomingEventsSection from "../components/UpcomingEventsSection.astro";
import ClubsSection from "../components/ClubsSection.astro";
import { getCollection } from "astro:content";
import { expandEventsToOccurrences } from "../utils/events";
import { getTownPagePath } from "../utils/towns";

const allClubs = (await getCollection("clubs")).filter((c) => c.data.active);
const shuffledClubs = [...allClubs].sort(() => Math.random() - 0.5).slice(0, 9);

const towns = Array.from(new Set(allClubs.map((c) => c.data.town))).sort(
  (a, b) => a.localeCompare(b, "nl"),
);

const totalRides = allClubs.reduce(
  (sum, c) => sum + (c.data.rides?.length ?? 0),
  0,
);

const now = new Date();
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const allEvents = await getCollection("events");

const allUpcomingEvents = expandEventsToOccurrences(allEvents)
  .filter((occurrence) => occurrence.occurrenceDate >= today)
  .sort((a, b) => a.occurrenceDate.getTime() - b.occurrenceDate.getTime());
const upcomingEvents = allUpcomingEvents.slice(0, 6);
---

<Layout
  title="WielerWaas"
  description="Ontdek wielerclubs en evenementen in het Waasland. Bekijk wanneer en waar ze vertrekken."
>
  <section class="ww-hero">
    <svg class="wheels" width="520" height="260" aria-hidden="true">
      <use href="#ww-wheels-big"></use>
    </svg>
    <div class="ww-wrap">
      <div class="ww-hero-grid">
        <div>
          <div class="kicker">
            Community Platform · Wielrennen in het Waasland
          </div>
          <h1>Vind je<br />Peloton.<br /><em>Trap mee.</em></h1>
          <p class="lede">
            Ontdek wielerclubs en evenementen in het Waasland. Bekijk wanneer en
            waar ze vertrekken en sluit je aan bij een groep die bij jou past.
          </p>
          <div class="ww-hero-actions">
            <a href="/clubs" class="ww-btn ww-btn-red" title="Bekijk alle clubs"
              >Bekijk alle clubs →</a
            >
            <a
              href="/add-club"
              class="ww-btn ww-btn-outline-chalk"
              title="Voeg je club toe"
            >
              Voeg je club toe
            </a>
          </div>
        </div>

        <div>
          <div
            style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--chalk); opacity: .6; margin-bottom: 10px;"
          >
            · Live statistieken
          </div>
          <div class="ww-hero-stats">
            <div class="s">
              <div class="n">{allClubs.length}</div>
              <div class="l">Clubs</div>
            </div>
            <div class="s">
              <div class="n">{totalRides}</div>
              <div class="l">Wekelijkse ritten</div>
            </div>
            <div class="s">
              <div class="n">{towns.length}</div>
              <div class="l">Gemeenten</div>
            </div>
            <div class="s">
              <div class="n">{allUpcomingEvents.length}</div>
              <div class="l">Evenementen</div>
            </div>
          </div>
          <div class="ww-hero-region">
            <span class="mono">Regio Waasland</span>
            <div class="towns">
              {
                towns.slice(0, 8).map((town, i) => (
                  <>
                    {i > 0 && " · "}
                    <a
                      href={getTownPagePath(town)}
                      title={`Bekijk clubs in ${town}`}
                    >
                      {town}
                    </a>
                  </>
                ))
              }
              {towns.length > 8 && <span> · …</span>}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <div class="ww-checker ww-checker-red"></div>

  <WeeklyRidesSection clubs={allClubs} />

  <UpcomingEventsSection upcomingEvents={upcomingEvents} />

  <ClubsSection clubs={shuffledClubs} totalCount={allClubs.length} />

  <AddClubCta />
</Layout>
