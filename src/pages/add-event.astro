---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Voeg je evenement toe — WielerWaas"
  description="Zet jouw wielerevenement op WielerWaas. Bereik fietsers in het Waasland."
>
  <section class="ww-page-hero">
    <div class="ww-wrap">
      <div class="kicker">Community</div>
      <h1>Voeg je<br /><em>evenement toe.</em></h1>
      <p>
        Organiseer jij een rit of wielerevenement in de regio? Vul het
        onderstaande formulier in en we nemen contact met je op om je evenement
        zo snel mogelijk op de kalender te zetten.
      </p>
    </div>
  </section>
  <div class="ww-checker ww-checker-red"></div>

  <section class="ww-band white">
    <div class="ww-wrap" style="padding: 56px 0;">
      <div class="ww-card" style="margin-bottom: 24px;">
        <div
          class="kicker"
          style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 6px;"
        >
          Wat hebben we nodig?
        </div>
        <p style="color: var(--ink-2); margin: 0;">
          We vragen basisgegevens over je evenement: naam, type rit, start- en
          einddatum, startuur, gemeente, locatie en wie het organiseert.
        </p>
      </div>

      <article class="ww-card">
        <h2
          style="font-family: 'Anton', sans-serif; font-size: 28px; text-transform: uppercase; margin: 0 0 20px;"
        >
          Vul het formulier in
        </h2>
        <form
          action="https://formspree.io/f/xaqlgaey"
          method="POST"
          class="ww-form"
        >
          <label class="field row full">
            <span class="ww-label"
              >Naam van het evenement <span class="req">*</span></span
            >
            <input
              type="text"
              id="eventName"
              name="eventName"
              required
              class="ww-input"
              placeholder="De officiële naam van je rit of evenement"
            />
            <span class="hint">De officiële naam van je rit of evenement.</span>
          </label>

          <div class="row">
            <label class="field">
              <span class="ww-label">Frequentie <span class="req">*</span></span
              >
              <select
                id="frequency"
                name="frequency"
                required
                class="ww-select"
              >
                <option value="once">Eenmalig</option>
                <option value="weekly">Wekelijks</option>
                <option value="monthly">Maandelijks</option>
              </select>
              <span class="hint"
                >Kies of het om een eenmalige of terugkerende rit gaat.</span
              >
            </label>
            <label class="field">
              <span class="ww-label">Startuur <span class="req">*</span></span>
              <input
                type="time"
                id="startTime"
                name="startTime"
                required
                class="ww-input"
              />
              <span class="hint">Het uur waarop deelnemers starten.</span>
            </label>
          </div>

          <div class="row">
            <label class="field">
              <span class="ww-label">Startdatum <span class="req">*</span></span
              >
              <input
                type="date"
                id="startDate"
                name="startDate"
                required
                class="ww-input"
              />
              <span class="hint">Vanaf wanneer?</span>
            </label>
            <label class="field">
              <span class="ww-label">Einddatum <span class="req">*</span></span>
              <input
                type="date"
                id="endDate"
                name="endDate"
                required
                class="ww-input"
              />
              <span class="hint">Tot wanneer blijft de reeks lopen?</span>
            </label>
          </div>

          <div class="row">
            <label class="field">
              <span class="ww-label">Gemeente <span class="req">*</span></span>
              <input
                type="text"
                id="town"
                name="town"
                required
                class="ww-input"
                placeholder="Bijv. Beveren"
              />
              <span class="hint"
                >In welke gemeente vindt het evenement plaats?</span
              >
            </label>
            <label class="field">
              <span class="ww-label">Locatie <span class="req">*</span></span>
              <input
                type="text"
                id="location"
                name="location"
                required
                class="ww-input"
                placeholder="Vertrekplaats of adres"
              />
              <span class="hint">Vertrekplaats of adres van het evenement.</span
              >
            </label>
          </div>

          <label class="field row full">
            <span class="ww-label">Organisator <span class="req">*</span></span>
            <input
              type="text"
              id="organizer"
              name="organizer"
              required
              class="ww-input"
              placeholder="Naam van de club of organisatie"
            />
            <span class="hint"
              >Naam van de club of organisatie achter het evenement.</span
            >
          </label>

          <div class="row">
            <label class="field">
              <span class="ww-label">Website (optioneel)</span>
              <input
                type="url"
                id="website"
                name="website"
                class="ww-input"
                placeholder="https://..."
              />
              <span class="hint"
                >Link naar een website of socialpagina met extra info.</span
              >
            </label>
            <label class="field">
              <span class="ww-label">E-mailadres (optioneel)</span>
              <input
                type="email"
                id="contactEmail"
                name="contactEmail"
                class="ww-input"
                placeholder="info@voorbeeld.be"
              />
              <span class="hint">Contactadres voor vragen.</span>
            </label>
          </div>

          <div class="ww-form-actions">
            <button type="submit" class="ww-btn ww-btn-red">Verstuur →</button>
            <button type="reset" class="ww-btn ww-btn-outline-ink"
              >Wissen</button
            >
          </div>
          <p
            style="font-size: 12px; color: var(--mute); text-align: center; margin: 0;"
          >
            <span class="req" style="color: var(--red);">*</span> Verplichte velden
          </p>
        </form>
      </article>
    </div>
  </section>
</Layout>
