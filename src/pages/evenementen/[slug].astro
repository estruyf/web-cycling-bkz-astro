---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { expandEventsToOccurrences } from "../../utils/events";

export async function getStaticPaths() {
  const events = await getCollection("events");

  return events
    .filter((event) => event.data.active)
    .map((event) => ({
      params: { slug: event.id.replace(/\.md$/, "") },
      props: { event },
    }));
}

const { event } = Astro.props;
const { Content } = await event.render();

const now = new Date();
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

const occurrences = expandEventsToOccurrences([event]).sort(
  (a, b) => a.occurrenceDate.getTime() - b.occurrenceDate.getTime(),
);

const upcomingOccurrences = occurrences.filter(
  (occurrence) => occurrence.occurrenceDate >= today,
);
const pastOccurrences = occurrences.filter(
  (occurrence) => occurrence.occurrenceDate < today,
);

const startDate = event.data.startDate ?? event.data.date;
const endDate = event.data.endDate ?? event.data.startDate ?? event.data.date;

const formatDate = (inputDate: Date) =>
  new Intl.DateTimeFormat("nl-BE", {
    weekday: "long",
    day: "2-digit",
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  }).format(inputDate);

const frequencyLabels: Record<string, string> = {
  once: "Eenmalig",
  weekly: "Wekelijks",
  monthly: "Maandelijks",
};
---

<Layout title={`${event.data.name} — WielerWaas`} description={event.data.name}>
  <section class="ww-page-hero">
    <div class="ww-wrap">
      <a
        href="/evenementen"
        style="display: inline-flex; align-items: center; gap: 6px; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--chalk); opacity: .75; text-decoration: none; margin-bottom: 20px;"
      >
        ← Terug naar evenementen
      </a>
      <div class="kicker">
        {frequencyLabels[event.data.frequency ?? "once"]}
        {event.data.town}
      </div>
      <h1>{event.data.name}<br /><em>{event.data.town}.</em></h1>
      <p>Georganiseerd door {event.data.organizer} in {event.data.town}.</p>
    </div>
  </section>
  <div class="ww-checker ww-checker-red"></div>

  <section class="ww-band white">
    <div class="ww-wrap" style="padding-top: 40px; padding-bottom: 56px;">
      <div
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 24px;"
      >
        <div class="ww-card">
          <div
            class="kicker"
            style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 8px;"
          >
            Datum
          </div>
          {
            startDate && endDate ? (
              startDate.getTime() === endDate.getTime() ? (
                <p style="color: var(--ink); font-weight: 600; margin: 0;">
                  {formatDate(startDate)}
                </p>
              ) : (
                <>
                  <p style="color: var(--ink); font-weight: 600; margin: 0;">
                    Van {formatDate(startDate)}
                  </p>
                  <p style="color: var(--ink-2); margin: 4px 0 0; font-size: 14px;">
                    Tot {formatDate(endDate)}
                  </p>
                </>
              )
            ) : (
              <p style="color: var(--ink); font-weight: 600; margin: 0;">
                Nog te bepalen
              </p>
            )
          }
        </div>

        {
          event.data.time && (
            <div class="ww-card">
              <div
                class="kicker"
                style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 8px;"
              >
                Tijdstip
              </div>
              <p style="color: var(--ink); font-weight: 600; margin: 0;">
                {event.data.time}
              </p>
            </div>
          )
        }

        <div class="ww-card">
          <div
            class="kicker"
            style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 8px;"
          >
            Locatie
          </div>
          <p style="color: var(--ink); font-weight: 600; margin: 0;">
            {event.data.location}
          </p>
        </div>

        <div class="ww-card">
          <div
            class="kicker"
            style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 8px;"
          >
            Organisator
          </div>
          <p style="color: var(--ink); font-weight: 600; margin: 0;">
            {event.data.organizer}
          </p>
        </div>
      </div>

      <div
        style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 32px;"
      >
        {
          event.data.website && (
            <a
              href={event.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="ww-btn ww-btn-red"
              title="Ga naar de eventwebsite"
            >
              Naar eventwebsite →
            </a>
          )
        }
        {
          event.data.contactEmail && (
            <a
              href={`mailto:${event.data.contactEmail}`}
              class="ww-btn ww-btn-outline-ink"
              title="Stuur een e-mail naar de organisator"
            >
              {event.data.contactEmail}
            </a>
          )
        }
      </div>

      {
        upcomingOccurrences.length > 0 && (
          <article class="ww-card" style="margin-bottom: 24px;">
            <h2 style="font-family: 'Anton', sans-serif; font-size: 24px; text-transform: uppercase; margin: 0 0 16px;">
              Komende data
            </h2>
            <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 8px;">
              {upcomingOccurrences.slice(0, 12).map((occurrence) => (
                <li style="display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--ink-2);">
                  <span style="width: 8px; height: 8px; background: var(--red); display: inline-block;" />
                  <span>{formatDate(occurrence.occurrenceDate)}</span>
                </li>
              ))}
            </ul>
          </article>
        )
      }

      {
        pastOccurrences.length > 0 && (
          <article class="ww-card" style="margin-bottom: 24px;">
            <h2 style="font-family: 'Anton', sans-serif; font-size: 24px; text-transform: uppercase; margin: 0 0 16px;">
              Voorbije data
            </h2>
            <ul style="list-style: none; padding: 0; margin: 0; display: grid; gap: 8px;">
              {pastOccurrences
                .slice(-6)
                .reverse()
                .map((occurrence) => (
                  <li style="font-size: 14px; color: var(--mute);">
                    {formatDate(occurrence.occurrenceDate)}
                  </li>
                ))}
            </ul>
          </article>
        )
      }

      <article class="ww-card ww-prose">
        <h2>Over dit evenement</h2>
        <Content />
      </article>

      <p style="margin-top: 32px; font-size: 13px; color: var(--mute);">
        Zie je een fout op deze pagina? Laat het ons weten via
        <a
          href={`mailto:elio@struyfconsulting.be?subject=Probleem op evenementpagina: ${event.data.name}`}
          style="color: var(--red); text-decoration: underline;"
          title="Stuur een e-mail naar de beheerder">elio@struyfconsulting.be</a
        >.
      </p>
    </div>
  </section>
</Layout>
