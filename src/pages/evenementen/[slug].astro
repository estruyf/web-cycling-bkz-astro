---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { expandEventsToOccurrences } from "../../utils/events";

export async function getStaticPaths() {
  const events = await getCollection("events");

  return events
    .filter((event) => event.data.active)
    .map((event) => ({
      params: { slug: event.id.replace(/\.md$/, "") },
      props: { event },
    }));
}

const { event } = Astro.props;
const { Content } = await event.render();

const now = new Date();
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

const occurrences = expandEventsToOccurrences([event]).sort(
  (a, b) => a.occurrenceDate.getTime() - b.occurrenceDate.getTime(),
);

const upcomingOccurrences = occurrences.filter(
  (occurrence) => occurrence.occurrenceDate >= today,
);
const pastOccurrences = occurrences.filter(
  (occurrence) => occurrence.occurrenceDate < today,
);

const startDate = event.data.startDate ?? event.data.date;
const endDate = event.data.endDate ?? event.data.startDate ?? event.data.date;

const formatDate = (inputDate: Date) =>
  new Intl.DateTimeFormat("nl-BE", {
    weekday: "long",
    day: "2-digit",
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  }).format(inputDate);

const frequencyLabels = {
  once: "Eenmalig",
  weekly: "Wekelijks",
  monthly: "Maandelijks",
};
---

<Layout title={`${event.data.name} — WielerWaas`} description={event.data.name}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a
      href="/evenementen"
      class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-8 transition-colors"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"
        ></path>
      </svg>
      Terug naar evenementen
    </a>

    <div
      class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-8"
    >
      <div class="bg-gradient-to-r from-primary-600 to-primary-500 h-3"></div>
      <div class="p-8">
        <div class="flex flex-wrap items-start gap-3 mb-3">
          <h1 class="text-2xl font-extrabold text-gray-900">
            {event.data.name}
          </h1>
          <span
            class="bg-primary-100 text-primary-800 text-xs font-semibold px-3 py-1 rounded-full"
          >
            {frequencyLabels[event.data.frequency ?? "once"]}
          </span>
        </div>
        <p class="text-gray-500 leading-relaxed">
          Georganiseerd door {event.data.organizer} in {event.data.town}.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <div
          class="flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wide mb-2"
        >
          Datum
        </div>
        {
          startDate && endDate ? (
            startDate.getTime() === endDate.getTime() ? (
              <p class="text-gray-800 font-medium text-sm">
                {formatDate(startDate)}
              </p>
            ) : (
              <>
                <p class="text-gray-800 font-medium text-sm">
                  Van {formatDate(startDate)}
                </p>
                <p class="text-gray-600 text-sm">Tot {formatDate(endDate)}</p>
              </>
            )
          ) : (
            <p class="text-gray-800 font-medium text-sm">Nog te bepalen</p>
          )
        }
      </div>

      {
        event.data.time && (
          <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
            <div class="flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wide mb-2">
              Tijdstip
            </div>
            <p class="text-gray-800 font-medium text-sm">{event.data.time}</p>
          </div>
        )
      }

      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <div
          class="flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wide mb-2"
        >
          Locatie
        </div>
        <p class="text-gray-800 font-medium text-sm">{event.data.location}</p>
      </div>

      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
        <div
          class="flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wide mb-2"
        >
          Organisator
        </div>
        <p class="text-gray-800 font-medium text-sm">{event.data.organizer}</p>
      </div>
    </div>

    <div class="flex flex-wrap gap-4 mb-8">
      {
        event.data.website && (
          <a
            href={event.data.website}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-primary-600 hover:bg-primary-500 text-white px-4 py-2 text-sm font-semibold transition-colors"
          >
            Naar eventwebsite
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14 5h5m0 0v5m0-5L10 14M5 19h14"
              />
            </svg>
          </a>
        )
      }

      {
        event.data.contactEmail && (
          <a
            href={`mailto:${event.data.contactEmail}`}
            class="inline-flex items-center gap-2 rounded-lg border border-gray-200 hover:border-gray-300 bg-white text-gray-700 px-4 py-2 text-sm font-semibold transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              />
            </svg>
            {event.data.contactEmail}
          </a>
        )
      }
    </div>

    {
      upcomingOccurrences.length > 0 && (
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 mb-8">
          <h2 class="font-bold text-gray-900 mb-4">Komende data</h2>
          <ul class="space-y-2 text-sm text-gray-700">
            {upcomingOccurrences.slice(0, 12).map((occurrence) => (
              <li class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-primary-500" />
                <span>{formatDate(occurrence.occurrenceDate)}</span>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    {
      pastOccurrences.length > 0 && (
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 mb-8">
          <h2 class="font-bold text-gray-900 mb-4">Voorbije data</h2>
          <ul class="space-y-2 text-sm text-gray-500">
            {pastOccurrences
              .slice(-6)
              .reverse()
              .map((occurrence) => (
                <li>{formatDate(occurrence.occurrenceDate)}</li>
              ))}
          </ul>
        </div>
      )
    }

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
      <h2 class="font-bold text-gray-900 mb-5">Over dit evenement</h2>
      <div
        class="max-w-none text-base text-gray-800 leading-relaxed [&_p]:my-4 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:my-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:my-1.5 [&_strong]:font-bold [&_a]:text-primary-600 [&_a]:underline"
      >
        <Content />
      </div>
    </div>

    <div class="mt-8 py-5 text-sm text-gray-500">
      Zie je een fout op deze pagina? Laat het ons weten via
      <a
        href={`mailto:elio@struyfconsulting.be?subject=Probleem op evenementpagina: ${event.data.name}`}
        class="text-primary-600 hover:text-primary-700 underline"
        >elio@struyfconsulting.be</a
      >.
    </div>
  </div>
</Layout>
