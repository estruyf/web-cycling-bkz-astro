---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Voeg je club toe — WielerWaas"
  description="Zet jouw wielerclub op WielerWaas. Bereik fietsers in het Waasland."
>
  <section class="ww-page-hero">
    <div class="ww-wrap">
      <div class="kicker">Community</div>
      <h1>Voeg je<br /><em>club toe.</em></h1>
      <p>
        Wil jij jouw wielerclub op deze website zetten? Vul het onderstaande
        formulier in en we nemen contact met je op om je zo snel mogelijk
        vermeld te krijgen op WielerWaas.
      </p>
    </div>
  </section>
  <div class="ww-checker ww-checker-red"></div>

  <section class="ww-band white">
    <div class="ww-wrap" style="padding: 56px 0;">
      <div class="ww-card" style="margin-bottom: 24px;">
        <div
          class="kicker"
          style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 6px;"
        >
          Wat hebben we nodig?
        </div>
        <p style="color: var(--ink-2); margin: 0;">
          We vragen wat basisgegevens over je club: naam, locatie,
          contactgegevens, een korte beschrijving en je ritschema. Dit helpt
          wielrenners jouw club makkelijk te vinden en aan te sluiten.
        </p>
      </div>

      <article class="ww-card">
        <h2
          style="font-family: 'Anton', sans-serif; font-size: 28px; text-transform: uppercase; margin: 0 0 20px;"
        >
          Vul het formulier in
        </h2>
        <form
          action="https://formspree.io/f/mreowrbd"
          method="POST"
          class="ww-form"
        >
          <label class="field row full">
            <span class="ww-label">Clubnaam <span class="req">*</span></span>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="ww-input"
              placeholder="De officiële naam van je wielerclub"
            />
            <span class="hint">De officiële naam van je wielerclub.</span>
          </label>

          <div class="row">
            <label class="field">
              <span class="ww-label">Gemeente <span class="req">*</span></span>
              <input
                type="text"
                id="town"
                name="town"
                required
                class="ww-input"
                placeholder="Bijv. Beveren, Kruibeke, Zwijndrecht..."
              />
              <span class="hint">In welke gemeente ben je gevestigd?</span>
            </label>
            <label class="field">
              <span class="ww-label">Gender <span class="req">*</span></span>
              <select id="gender" name="gender" required class="ww-select">
                <option value="" disabled selected>Kies een optie</option>
                <option value="mixed">gemengd</option>
                <option value="men">mannen</option>
                <option value="women">vrouwen</option>
              </select>
              <span class="hint"
                >Voor wie is jullie club voornamelijk bedoeld?</span
              >
            </label>
          </div>

          <label class="field row full">
            <span class="ww-label"
              >Contactmailadres <span class="req">*</span></span
            >
            <input
              type="email"
              id="contactEmail"
              name="contactEmail"
              required
              class="ww-input"
              placeholder="contact@jouwclub.be"
            />
            <span class="hint"
              >Een e-mailadres waarop mensen jouw club kunnen bereiken.</span
            >
          </label>

          <label class="field row full">
            <span class="ww-label">Omschrijving <span class="req">*</span></span
            >
            <textarea
              id="shortDescription"
              name="shortDescription"
              required
              rows={3}
              class="ww-input"
              placeholder="Beschrijf je club in een paar paragrafen..."
            ></textarea>
            <span class="hint"
              >Dit verschijnt op je clubpagina. Kijk naar de andere clubpagina's
              voor inspiratie.</span
            >
          </label>

          <label class="field row full">
            <span class="ww-label">Vertrekpunt <span class="req">*</span></span>
            <input
              type="text"
              id="meetingPoint"
              name="meetingPoint"
              required
              class="ww-input"
              placeholder="Adres of plaatsnaam"
            />
            <span class="hint"
              >Waar vertrekken jullie? Geef het adres of een duidelijke
              plaatsnaam.</span
            >
          </label>

          <div class="row">
            <label class="field">
              <span class="ww-label">Website of Facebook (optioneel)</span>
              <input
                type="url"
                id="website"
                name="website"
                class="ww-input"
                placeholder="https://..."
              />
              <span class="hint"
                >Je clubwebsite of Facebookpagina, als je die hebt.</span
              >
            </label>
            <label class="field">
              <span class="ww-label">Logo URL (optioneel)</span>
              <input
                type="url"
                id="logo"
                name="logo"
                class="ww-input"
                placeholder="Link naar je clublogo"
              />
              <span class="hint"
                >Voeg je clublogo toe als PNG of JPG, of stuur een link.</span
              >
            </label>
          </div>

          <label class="field row full">
            <span class="ww-label">Ritschema <span class="req">*</span></span>
            <textarea
              id="rides"
              name="rides"
              required
              rows={4}
              class="ww-input"
              placeholder={"Woensdag, 19:00 - Clubrit (open voor iedereen) - 30gem\nZondag, 09:00 - Trainingsrit (enkel voor leden) - 34gem"}
            ></textarea>
            <span class="hint"
              >Per rit: dag van de week, vertrektijdstip, type rit en of deze
              open is voor iedereen of enkel voor leden.</span
            >
          </label>

          <div class="ww-form-actions">
            <button type="submit" class="ww-btn ww-btn-red">Verstuur →</button>
            <button type="reset" class="ww-btn ww-btn-outline-ink"
              >Wissen</button
            >
          </div>
          <p
            style="font-size: 12px; color: var(--mute); text-align: center; margin: 0;"
          >
            <span class="req" style="color: var(--red);">*</span> Verplichte velden
          </p>
        </form>
      </article>
    </div>
  </section>
</Layout>
