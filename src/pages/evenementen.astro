---
import Layout from "../layouts/Layout.astro";
import EventCard from "../components/EventCard.astro";
import { getCollection } from "astro:content";

const now = new Date();

const events = (await getCollection("events"))
  .filter((e) => e.data.active && new Date(e.data.date) >= new Date(now.getFullYear(), now.getMonth(), now.getDate()))
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const pastEvents = (await getCollection("events"))
  .filter((e) => e.data.active && new Date(e.data.date) < new Date(now.getFullYear(), now.getMonth(), now.getDate()))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout
  title="Evenementen — Cycling BKZ"
  description="Overzicht van wielerevenementen en ritten georganiseerd door clubs in de regio."
>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-10">
      <h1 class="text-3xl font-extrabold text-gray-900">Evenementen</h1>
      <p class="text-gray-500 mt-2">
        Ritten en wielerevenementen georganiseerd door clubs in en rond de regio.
      </p>
    </div>

    {events.length > 0 ? (
      <div class="space-y-4">
        {events.map((event) => (
          <EventCard
            name={event.data.name}
            date={event.data.date}
            time={event.data.time}
            organizer={event.data.organizer}
            location={event.data.location}
            website={event.data.website}
            slug={event.id}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
        <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-gray-500 font-medium">Geen aankomende evenementen</p>
        <p class="text-gray-400 text-sm mt-1">Kom later nog eens terug!</p>
      </div>
    )}

    {pastEvents.length > 0 && (
      <div class="mt-16">
        <h2 class="text-xl font-bold text-gray-400 mb-4">Voorbije evenementen</h2>
        <div class="space-y-4 opacity-60">
          {pastEvents.map((event) => (
            <EventCard
              name={event.data.name}
              date={event.data.date}
              time={event.data.time}
              organizer={event.data.organizer}
              location={event.data.location}
              website={event.data.website}
              slug={event.id}
            />
          ))}
        </div>
      </div>
    )}
  </section>
</Layout>
