---
import Layout from "../../layouts/Layout.astro";
import RideSchedule from "../../components/RideSchedule.astro";
import GenderBadge from "../../components/GenderBadge.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const clubs = await getCollection("clubs");
  return clubs.map((club) => ({
    params: { slug: club.id.replace(/\.md$/, "") },
    props: { club },
  }));
}

const { club } = Astro.props;
const { Content } = await club.render();
const {
  name,
  town,
  shortDescription,
  meetingPoint,
  meetingPointDetail,
  website,
  contactEmail,
  rides,
  logo,
  gender,
  claimable,
} = club.data;
---

<Layout title={`${name} — WielerWaas`} description={shortDescription ?? name}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a
      href="/clubs"
      class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-8 transition-colors"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"
        ></path>
      </svg>
      Terug naar clubs
    </a>

    <div
      class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-8"
    >
      <div class="bg-gradient-to-r from-primary-600 to-primary-500 h-3"></div>
      <div class="p-8">
        <div class="flex items-start gap-5">
          {
            logo ? (
              <img
                src={logo}
                alt={name}
                class="w-20 h-20 rounded-2xl object-cover border border-gray-100 shadow-sm shrink-0"
              />
            ) : (
              <div class="w-20 h-20 rounded-2xl bg-primary-100 flex items-center justify-center text-primary-700 font-extrabold text-3xl shrink-0">
                {name.charAt(0)}
              </div>
            )
          }
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-3 mb-1">
              <h1 class="text-2xl font-extrabold text-gray-900">{name}</h1>
              <span
                class="bg-primary-100 text-primary-800 text-xs font-semibold px-3 py-1 rounded-full"
                >{town}</span
              >
              <GenderBadge gender={gender} />
            </div>
            {
              shortDescription && (
                <p class="text-gray-500 leading-relaxed">{shortDescription}</p>
              )
            }
          </div>
        </div>
      </div>
    </div>

    {
      claimable && (
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mb-8">
          <div class="flex items-start gap-3">
            <svg
              class="w-6 h-6 text-amber-500 shrink-0 mt-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <div>
              <h3 class="font-semibold text-amber-900 mb-1">
                Is dit jouw club?
              </h3>
              <p class="text-sm text-amber-800 leading-relaxed">
                De informatie op deze pagina is nog onvolledig. Ben jij lid of
                verantwoordelijke van {name}? Vul het
                <a
                  href="/add-club"
                  class="underline font-medium hover:text-amber-950"
                >
                  formulier
                </a>{" "}
                in en we zorgen ervoor dat jullie gegevens up-to-date staan op
                WielerWaas.
              </p>
            </div>
          </div>
        </div>
      )
    }

    {
      (meetingPoint || website || contactEmail) && (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
          {meetingPoint && (
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
              <div class="flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wide mb-2">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                  />
                </svg>
                Vertrekpunt
              </div>
              <p class="text-gray-800 font-medium text-sm">{meetingPoint}</p>
              {meetingPointDetail && (
                <p class="text-gray-500 text-xs mt-1">{meetingPointDetail}</p>
              )}
            </div>
          )}

          {website && (
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
              <div class="flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wide mb-2">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                  />
                </svg>
                Website
              </div>
              <a
                href={website}
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary-500 hover:text-primary-700 font-medium text-sm break-all"
              >
                {website.replace(/^https?:\/\//, "")}
              </a>
            </div>
          )}

          {contactEmail && (
            <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">
              <div class="flex items-center gap-2 text-gray-400 text-xs font-semibold uppercase tracking-wide mb-2">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  />
                </svg>
                Contact
              </div>
              <a
                href={`mailto:${contactEmail}`}
                class="text-primary-500 hover:text-primary-700 font-medium text-sm break-all"
              >
                {contactEmail}
              </a>
            </div>
          )}
        </div>
      )
    }

    {
      meetingPoint && (
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-8">
          <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="font-bold text-gray-900">Vertrekpunt op kaart</h2>
          </div>
          <div id="club-map" class="h-[300px] w-full" />
        </div>
      )
    }

    {
      rides && rides.length > 0 && (
        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden mb-8">
          <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="font-bold text-gray-900">Weekschema ritten</h2>
          </div>
          <RideSchedule rides={rides.map(r => ({ ...r, gender: r.gender ?? gender }))} />
        </div>
      )
    }

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
      <h2 class="font-bold text-gray-900 mb-5">Over {name}</h2>
      <div
        class="prose prose-sm prose-gray max-w-none prose-headings:font-bold prose-a:text-primary-500"
      >
        <Content />
      </div>
    </div>

    <div class="mt-8 py-5 text-sm text-gray-500">
      Zie je een fout op deze pagina? Laat het ons weten via
      <a
        href={`mailto:elio@struyfconsulting.be?subject=Probleem op clubpagina: ${name}`}
        class="text-primary-600 hover:text-primary-700 underline"
        >elio@struyfconsulting.be</a
      >.
    </div>
  </div>

  <script define:vars={{ meetingPoint, town }}>
    const mapContainer = document.getElementById("club-map");
    if (mapContainer) {
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
      document.head.appendChild(link);

      // Build search queries: full address, then progressively simpler fallbacks
      function buildQueries(mp, t) {
        const queries = [];
        const parts = mp.split(",").map((s) => s.trim());
        // Find the first part that looks like a street address (contains a number)
        const streetIdx = parts.findIndex((p) => /\d/.test(p));
        if (streetIdx > 0) {
          // Strip venue name, keep from street onwards
          queries.push(
            parts.slice(streetIdx).join(", ") + ", " + t + ", Belgium",
          );
        }
        queries.push(mp + ", " + t + ", Belgium");
        // Just town as last resort
        queries.push(t + ", Belgium");
        return queries;
      }

      async function geocode(queries) {
        for (const q of queries) {
          const res = await fetch(
            `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=1`,
            { headers: { "User-Agent": "WielerWaas/1.0" } },
          );
          const data = await res.json();
          if (data.length > 0) return data[0];
        }
        return null;
      }

      const script = document.createElement("script");
      script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      script.onload = async () => {
        try {
          const queries = buildQueries(meetingPoint, town);
          const result = await geocode(queries);
          if (result) {
            const lat = parseFloat(result.lat);
            const lon = parseFloat(result.lon);
            const map = L.map("club-map").setView([lat, lon], 16);
            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
              attribution:
                '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            }).addTo(map);
            L.marker([lat, lon])
              .addTo(map)
              .bindPopup(`<strong>${meetingPoint}</strong>`)
              .openPopup();
          } else {
            mapContainer.innerHTML =
              '<p class="text-gray-400 text-sm text-center py-8">Locatie kon niet worden gevonden op de kaart.</p>';
          }
        } catch {
          mapContainer.innerHTML =
            '<p class="text-gray-400 text-sm text-center py-8">Kaart kon niet worden geladen.</p>';
        }
      };
      document.head.appendChild(script);
    }
  </script>
</Layout>
