---
import Layout from "../../layouts/Layout.astro";
import RideSchedule from "../../components/RideSchedule.astro";
import GenderBadge from "../../components/GenderBadge.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const clubs = await getCollection("clubs");
  return clubs.map((club) => ({
    params: { slug: club.id.replace(/\.md$/, "") },
    props: { club },
  }));
}

const { club } = Astro.props;
const { Content } = await club.render();
const {
  name,
  town,
  shortDescription,
  meetingPoint,
  meetingPointDetail,
  website,
  contactEmail,
  rides,
  logo,
  gender,
  claimable,
} = club.data;
---

<Layout title={`${name} — WielerWaas`} description={shortDescription ?? name}>
  <section class="ww-page-hero">
    <div class="ww-wrap">
      <a
        href="/clubs"
        style="display: inline-flex; align-items: center; gap: 6px; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--chalk); opacity: .75; text-decoration: none; margin-bottom: 20px;"
      >
        ← Terug naar clubs
      </a>
      <div class="kicker">{town}</div>
      <h1>
        {name}<br /><em>{town}.</em>
      </h1>
      {shortDescription && <p>{shortDescription}</p>}
      <div
        style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 20px; align-items: center;"
      >
        {
          logo ? (
            <img
              src={logo}
              alt={name}
              style="width: 64px; height: 64px; border: 2px solid var(--chalk); background: var(--chalk); object-fit: cover;"
            />
          ) : null
        }
        <GenderBadge gender={gender} />
      </div>
    </div>
  </section>
  <div class="ww-checker ww-checker-red"></div>

  <section class="ww-band white">
    <div class="ww-wrap" style="padding: 48px 0 56px;">
      {
        claimable && (
          <div
            class="ww-card"
            style="margin-bottom: 24px; border-color: var(--red); background: oklch(0.97 0.04 85);"
          >
            <div
              class="kicker"
              style="font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 6px;"
            >
              Is dit jouw club?
            </div>
            <p style="color: var(--ink-2); margin: 0;">
              De informatie op deze pagina is nog onvolledig. Ben jij lid of
              verantwoordelijke van {name}? Vul het{" "}
              <a
                href="/add-club"
                style="color: var(--red); text-decoration: underline; font-weight: 600;"
              >
                formulier
              </a>{" "}
              in en we zorgen ervoor dat jullie gegevens up-to-date staan op
              WielerWaas.
            </p>
          </div>
        )
      }

      {
        (meetingPoint || website || contactEmail) && (
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-bottom: 24px;">
            {meetingPoint && (
              <div class="ww-card">
                <div
                  class="kicker"
                  style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 8px;"
                >
                  Vertrekpunt
                </div>
                <p style="font-weight: 600; color: var(--ink); margin: 0;">
                  {meetingPoint}
                </p>
                {meetingPointDetail && (
                  <p style="color: var(--mute); font-size: 13px; margin: 4px 0 0;">
                    {meetingPointDetail}
                  </p>
                )}
              </div>
            )}

            {website && (
              <div class="ww-card">
                <div
                  class="kicker"
                  style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 8px;"
                >
                  Website
                </div>
                <a
                  href={website}
                  target="_blank"
                  rel="noopener noreferrer"
                  style="color: var(--red); font-weight: 600; word-break: break-all; text-decoration: underline;"
                  title={`Bezoek de website van ${name}`}
                >
                  {website.replace(/^https?:\/\//, "")}
                </a>
              </div>
            )}

            {contactEmail && (
              <div class="ww-card">
                <div
                  class="kicker"
                  style="font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 8px;"
                >
                  Contact
                </div>
                <a
                  href={`mailto:${contactEmail}`}
                  style="color: var(--red); font-weight: 600; word-break: break-all; text-decoration: underline;"
                  title={`Neem contact op met ${name}`}
                >
                  {contactEmail}
                </a>
              </div>
            )}
          </div>
        )
      }

      {
        meetingPoint && (
          <div class="ww-card" style="margin-bottom: 24px; padding: 0;">
            <div style="padding: 16px 22px; border-bottom: 2px solid var(--ink);">
              <h2 style="font-family: 'Anton', sans-serif; font-size: 22px; text-transform: uppercase; margin: 0;">
                Vertrekpunt op kaart
              </h2>
            </div>
            <div id="club-map" style="height: 300px; width: 100%;" />
          </div>
        )
      }

      {
        rides && rides.length > 0 && (
          <div style="margin-bottom: 24px;">
            <header class="ww-section-head" style="margin-bottom: 14px;">
              <div>
                <div class="num">Weekschema</div>
                <h2>Ritten</h2>
              </div>
            </header>
            <RideSchedule
              rides={rides.map((r) => ({
                ...r,
                gender: r.gender ?? gender,
              }))}
            />
          </div>
        )
      }

      <article class="ww-card ww-prose">
        <h2>Over {name}</h2>
        <Content />
      </article>

      <p style="margin-top: 32px; font-size: 13px; color: var(--mute);">
        Zie je een fout op deze pagina? Laat het ons weten via
        <a
          href={`mailto:elio@struyfconsulting.be?subject=Probleem op clubpagina: ${name}`}
          style="color: var(--red); text-decoration: underline;"
          title="Stuur een e-mail naar de beheerder">elio@struyfconsulting.be</a
        >.
      </p>
    </div>
  </section>

  <script define:vars={{ meetingPoint, town }}>
    const mapContainer = document.getElementById("club-map");
    if (mapContainer) {
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
      document.head.appendChild(link);

      function buildQueries(mp, t) {
        const queries = [];
        const parts = mp.split(",").map((s) => s.trim());
        const streetIdx = parts.findIndex((p) => /\d/.test(p));
        if (streetIdx > 0) {
          queries.push(
            parts.slice(streetIdx).join(", ") + ", " + t + ", Belgium",
          );
        }
        queries.push(mp + ", " + t + ", Belgium");
        queries.push(t + ", Belgium");
        return queries;
      }

      async function geocode(queries) {
        for (const q of queries) {
          const res = await fetch(
            `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&limit=1`,
            { headers: { "User-Agent": "WielerWaas/1.0" } },
          );
          const data = await res.json();
          if (data.length > 0) return data[0];
        }
        return null;
      }

      const script = document.createElement("script");
      script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      script.onload = async () => {
        try {
          const queries = buildQueries(meetingPoint, town);
          const result = await geocode(queries);
          if (result) {
            const lat = parseFloat(result.lat);
            const lon = parseFloat(result.lon);
            const map = L.map("club-map").setView([lat, lon], 16);
            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
              attribution:
                '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            }).addTo(map);
            L.marker([lat, lon])
              .addTo(map)
              .bindPopup(`<strong>${meetingPoint}</strong>`)
              .openPopup();
          } else {
            mapContainer.innerHTML =
              '<p style="color: var(--mute); font-size: 13px; text-align: center; padding: 32px 0;">Locatie kon niet worden gevonden op de kaart.</p>';
          }
        } catch {
          mapContainer.innerHTML =
            '<p style="color: var(--mute); font-size: 13px; text-align: center; padding: 32px 0;">Kaart kon niet worden geladen.</p>';
        }
      };
      document.head.appendChild(script);
    }
  </script>
</Layout>
