---
import Layout from "../../layouts/Layout.astro";
import ClubCard from "../../components/ClubCard.astro";
import AddClubCta from "../../components/AddClubCta.astro";
import { getCollection } from "astro:content";

const allClubs = (await getCollection("clubs")).filter((c) => c.data.active);
const towns = ["Beveren", "Kruibeke", "Melsele", "Zwijndrecht"] as const;
---

<Layout
  title="Wielrenclubs — Cycling BKZ"
  description="Bekijk alle wielrenclubs in Beveren, Kruibeke en Zwijndrecht."
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Wielrenclubs</h1>
      <p class="text-gray-500">
        Alle actieve clubs in de regio Beveren-Kruibeke-Zwijndrecht.
      </p>
    </div>

    {
      towns.map((town) => {
        const townClubs = allClubs.filter((c) => c.data.town === town);
        if (townClubs.length === 0) return null;
        return (
          <div class="mb-12">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-1 h-7 bg-primary-500 rounded-full" />
              <h2 class="text-xl font-bold text-gray-900">{town}</h2>
              <span class="text-sm text-gray-400">
                {townClubs.length} club{townClubs.length !== 1 ? "s" : ""}
              </span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
              {townClubs.map((club) => (
                <ClubCard
                  name={club.data.name}
                  slug={club.id.replace(/\.md$/, "")}
                  town={club.data.town}
                  shortDescription={club.data.shortDescription}
                  meetingPoint={club.data.meetingPoint}
                  rides={club.data.rides}
                  logo={club.data.logo}
                />
              ))}
            </div>
          </div>
        );
      })
    }

    <AddClubCta
      variant="light"
      title="Staat jouw club er niet bij?"
      description="Stuur je clubgegevens door en we zetten je op de website."
    />
  </div>
</Layout>
