---
import Layout from "../../layouts/Layout.astro";
import ClubCard from "../../components/ClubCard.astro";
import AddClubCta from "../../components/AddClubCta.astro";
import { getCollection } from "astro:content";

const allClubs = (await getCollection("clubs")).filter((c) => c.data.active);
const towns = [
  "Beveren",
  "Kruibeke",
  "Melsele",
  "Zwijndrecht",
  "Vrasene",
] as const;
const dayOrder = [
  "Monday",
  "Tuesday",
  "Wednesday",
  "Thursday",
  "Friday",
  "Saturday",
  "Sunday",
];
const dayLabels: Record<string, string> = {
  Monday: "Maandag",
  Tuesday: "Dinsdag",
  Wednesday: "Woensdag",
  Thursday: "Donderdag",
  Friday: "Vrijdag",
  Saturday: "Zaterdag",
  Sunday: "Zondag",
};

const uniqueDays = Array.from(
  new Set(
    allClubs.flatMap((club) => (club.data.rides ?? []).map((ride) => ride.day)),
  ),
).sort((a, b) => dayOrder.indexOf(a) - dayOrder.indexOf(b));
---

<Layout
  title="Wielerclubs — WielerWaas"
  description="Bekijk alle wielerclubs van WielerWaas."
>
  <section class="ww-page-hero">
    <div class="ww-wrap">
      <div class="kicker">Overzicht</div>
      <h1>Alle<br /><em>clubs.</em></h1>
      <p>Alle actieve wielerclubs uit onze community in het Waasland.</p>
    </div>
  </section>
  <div class="ww-checker ww-checker-red"></div>

  <section class="ww-band white">
    <div class="ww-wrap" style="padding-top: 40px; padding-bottom: 56px;">
      <div class="ww-filters" style="border-top: 0;">
        <input
          id="club-filter-search"
          type="search"
          placeholder="Zoek op clubnaam..."
          class="ww-input"
          style="flex: 1; min-width: 200px;"
        />
        <select id="club-filter-town" class="ww-select">
          <option value="">Alle gemeenten</option>
          {towns.map((town) => <option value={town}>{town}</option>)}
        </select>
        <select id="club-filter-day" class="ww-select">
          <option value="">Alle dagen</option>
          {
            uniqueDays.map((day) => (
              <option value={day}>{dayLabels[day] ?? day}</option>
            ))
          }
        </select>
        <select id="club-filter-gender" class="ww-select">
          <option value="">Alle groepen</option>
          <option value="women">Vrouwen</option>
          <option value="men">Mannen</option>
          <option value="mixed">Gemengd</option>
        </select>
        <button
          id="club-filter-reset"
          type="button"
          class="ww-btn ww-btn-outline-ink"
        >
          Reset
        </button>
      </div>

      {
        towns.map((town) => {
          const townClubs = allClubs.filter((c) => c.data.town === town);
          if (townClubs.length === 0) return null;
          return (
            <div style="margin-bottom: 48px;" data-town-section>
              <header class="ww-section-head" style="margin-bottom: 18px;">
                <div>
                  <h2>
                    {town}
                    <em
                      style="margin-left: 12px; font-size: .6em;"
                      data-town-count
                    >
                      {townClubs.length} club{townClubs.length !== 1 ? "s" : ""}
                    </em>
                  </h2>
                </div>
              </header>
              <div class="ww-clubs-grid">
                {townClubs.map((club) => (
                  <div
                    class="club-filter-item"
                    data-name={club.data.name.toLowerCase()}
                    data-town={club.data.town}
                    data-days={(club.data.rides ?? [])
                      .map((ride) => ride.day)
                      .join("|")}
                    data-types={(club.data.rides ?? [])
                      .map((ride) => ride.type)
                      .join("|")}
                    data-gender={club.data.gender ?? ""}
                  >
                    <ClubCard
                      name={club.data.name}
                      slug={club.id.replace(/\.md$/, "")}
                      town={club.data.town}
                      shortDescription={club.data.shortDescription}
                      meetingPoint={club.data.meetingPoint}
                      rides={club.data.rides}
                      logo={club.data.logo}
                      gender={club.data.gender}
                    />
                  </div>
                ))}
              </div>
            </div>
          );
        })
      }

      <div
        id="club-filter-empty"
        class="ww-card hidden"
        style="text-align: center; margin-bottom: 32px;"
      >
        <p
          style="font-family: 'Anton', sans-serif; font-size: 24px; margin: 0; text-transform: uppercase;"
        >
          Geen clubs gevonden
        </p>
        <p style="color: var(--mute); margin-top: 8px;">
          Probeer een andere filtercombinatie.
        </p>
      </div>

      <AddClubCta
        variant="light"
        title="Staat jouw club er niet bij?"
        description="Stuur je clubgegevens door en we zetten je op de website."
        cta="club"
      />
    </div>
  </section>
</Layout>

<script>
  function initClubFilters() {
    const townFilter = document.getElementById("club-filter-town");
    const dayFilter = document.getElementById("club-filter-day");
    const typeFilter = document.getElementById("club-filter-type");
    const genderFilter = document.getElementById("club-filter-gender");
    const searchFilter = document.getElementById(
      "club-filter-search",
    ) as HTMLInputElement | null;
    const resetBtn = document.getElementById("club-filter-reset");
    const noResults = document.getElementById("club-filter-empty");

    const filterItems = Array.from(
      document.querySelectorAll<HTMLElement>(".club-filter-item"),
    );
    const townSections = Array.from(
      document.querySelectorAll<HTMLElement>("[data-town-section]"),
    );

    if (!townFilter && filterItems.length === 0) return;

    const applyFilters = () => {
      const town = (townFilter as HTMLSelectElement | null)?.value ?? "";
      const day = (dayFilter as HTMLSelectElement | null)?.value ?? "";
      const type = (typeFilter as HTMLSelectElement | null)?.value ?? "";
      const gender = (genderFilter as HTMLSelectElement | null)?.value ?? "";
      const search = (searchFilter?.value ?? "").toLowerCase().trim();

      let visibleCount = 0;

      filterItems.forEach((item) => {
        const itemTown = item.dataset.town ?? "";
        const itemDays = (item.dataset.days ?? "").split("|");
        const itemTypes = (item.dataset.types ?? "").split("|");
        const itemGender = item.dataset.gender ?? "";
        const itemName = item.dataset.name ?? "";

        const matchesTown = !town || itemTown === town;
        const matchesDay = !day || itemDays.includes(day);
        const matchesType = !type || itemTypes.includes(type);
        const matchesGender = !gender || itemGender === gender;
        const matchesSearch = !search || itemName.includes(search);
        const matches =
          matchesTown &&
          matchesDay &&
          matchesType &&
          matchesGender &&
          matchesSearch;

        item.classList.toggle("hidden", !matches);
        if (matches) visibleCount += 1;
      });

      townSections.forEach((section) => {
        const sectionVisible = section.querySelectorAll(
          ".club-filter-item:not(.hidden)",
        ).length;
        section.classList.toggle("hidden", sectionVisible === 0);

        const countEl = section.querySelector<HTMLElement>("[data-town-count]");
        if (countEl) {
          countEl.textContent = `${sectionVisible} club${sectionVisible !== 1 ? "s" : ""}`;
        }
      });

      noResults?.classList.toggle("hidden", visibleCount > 0);
    };

    townFilter?.addEventListener("change", applyFilters);
    dayFilter?.addEventListener("change", applyFilters);
    typeFilter?.addEventListener("change", applyFilters);
    genderFilter?.addEventListener("change", applyFilters);
    searchFilter?.addEventListener("input", applyFilters);
    resetBtn?.addEventListener("click", () => {
      if (townFilter) (townFilter as HTMLSelectElement).value = "";
      if (dayFilter) (dayFilter as HTMLSelectElement).value = "";
      if (typeFilter) (typeFilter as HTMLSelectElement).value = "";
      if (genderFilter) (genderFilter as HTMLSelectElement).value = "";
      if (searchFilter) searchFilter.value = "";
      applyFilters();
    });
  }

  document.addEventListener("astro:page-load", initClubFilters);
</script>
