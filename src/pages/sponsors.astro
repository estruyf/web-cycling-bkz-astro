---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const sponsors = (await getCollection("sponsors"))
  .filter((s) => s.data.active)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Sponsors — WielerWaas"
  description="Steun het lokale wielrennen in het Waasland als sponsor."
  hideSponsors={true}
>
  <section class="ww-page-hero">
    <div class="ww-wrap">
      <div class="kicker">Partners</div>
      <h1>Onze<br /><em>sponsors</em></h1>
      <p>
        Deze organisaties steunen het lokale wielrennen in het Waasland. We zijn
        hen dankbaar voor hun bijdrage aan de wielerwereld.
      </p>
    </div>
  </section>
  <div class="ww-checker ww-checker-red"></div>

  <section class="ww-band white">
    <div class="ww-wrap" style="padding: 56px 0;">
      {
        sponsors.length > 0 ? (
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 56px;">
            {sponsors.map((sponsor) => (
              <a
                href={sponsor.data.website || "#"}
                target="_blank"
                rel="noopener noreferrer"
                class="ww-sponsor-logo ww-sponsor-logo-large"
                style="height: 180px;"
                title={`Bezoek de website van ${sponsor.data.name}`}
              >
                {sponsor.data.logo ? (
                  <img src={sponsor.data.logo} alt={sponsor.data.name} />
                ) : (
                  <span>{sponsor.data.name}</span>
                )}
              </a>
            ))}
          </div>
        ) : (
          <div class="ww-card" style="text-align: center; margin-bottom: 56px;">
            <p style="font-family: 'Anton', sans-serif; font-size: 24px; margin: 0; text-transform: uppercase;">
              Nog geen sponsors
            </p>
            <p style="color: var(--mute); margin-top: 8px;">
              Wees de eerste om het lokale wielrennen te steunen.
            </p>
          </div>
        )
      }

      <section
        class="ww-cta-band"
        style="margin: 0 -100vw; padding: 64px 100vw;"
      >
        <div class="ww-wrap">
          <div>
            <h2 class="max-w-2/3">Word sponsor</h2>
            <p>
              Steun het lokale wielrennen en zet je bedrijf in de kijker bij een
              betrokken, actieve gemeenschap. Stuur ons een e-mail met je
              bedrijfsnaam, website en je logo (indien beschikbaar). We nemen
              snel contact met je op.
            </p>
          </div>
          <div class="ww-cta-actions">
            <a
              href="mailto:elio@struyfconsulting.be?subject=Sponsoring%20aanvraag"
              class="ww-btn ww-btn-chalk"
              title="Stuur een e-mail naar de beheerder"
            >
              Neem contact op →
            </a>
          </div>
        </div>
      </section>
    </div>
  </section>
</Layout>
