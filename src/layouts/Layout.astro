---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SponsorsSection from "../components/SponsorsSection.astro";

interface Props {
  title?: string;
  description?: string;
  hideSponsors?: boolean;
}

const {
  title = "WielerWaas",
  description = "Ontdek wielerclubs en evenementen in het Waasland. Bekijk wanneer en waar ze vertrekken.",
  hideSponsors = false,
} = Astro.props;
---

<!doctype html>
<html lang="nl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-gray-50 text-gray-900 font-[Inter,sans-serif] antialiased min-h-screen flex flex-col"
  >
    <Header />
    <main class="flex-1">
      <slot />
    </main>

    {!hideSponsors && <SponsorsSection />}
    <Footer />
  </body>
</html>
