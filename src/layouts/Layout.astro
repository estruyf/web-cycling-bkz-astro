---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SponsorsSection from "../components/SponsorsSection.astro";

interface Props {
  title?: string;
  description?: string;
  hideSponsors?: boolean;
}

const {
  title = "WielerWaas",
  description = "Ontdek wielerclubs en evenementen in het Waasland. Bekijk wanneer en waar ze vertrekken.",
  hideSponsors = false,
} = Astro.props;
---

<!doctype html>
<html lang="nl" class="scroll-smooth" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1a1613" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ClientRouter fallback="swap" />
  </head>
  <body class="min-h-screen flex flex-col">
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <symbol id="ww-bike" viewBox="0 0 152 63">
          <g
            fill="none"
            stroke="currentColor"
            stroke-width="5"
            stroke-miterlimit="10"
          >
            <path
              d="M2.5,31.34c0-.98.19-13.43,9.86-21.86.89-.77,4.53-3.83,10.24-5.63,1.54-.49,8.59-2.56,17.01-.25,5.18,1.42,7.51,3.58,11.36,5.83,9.37,5.48,19.31,6.56,24.95,6.69,13.55.31,24.51-6.12,25.5-6.69,4.32-2.51,6.1-4.51,11.06-5.9,7.09-1.98,13.24-.63,15.56,0,6.37,1.72,10.41,5.08,11.27,5.81,9.81,8.43,9.96,21.05,9.96,22.13-.04,10.13-5.38,18.59-11.76,23.37-.93.7-3.82,2.75-8.1,4.16-1.46.48-8.53,2.67-16.94.41-5.31-1.43-6.49-3.38-11.95-6.3-2.03-1.09-11.99-6.21-24.59-6.29-3.07-.02-14.27-.19-24.95,6.29-4.06,2.46-6.16,4.77-11.44,6.26-8.21,2.32-15.31.18-16.93-.35-4.27-1.38-7.16-3.41-8.13-4.13-6.28-4.65-11.97-13.1-11.98-23.55Z"
            ></path>
            <circle cx="31.41" cy="31.09" r="12.69"></circle>
            <circle cx="120.28" cy="31.09" r="12.69"></circle>
          </g>
        </symbol>
        <symbol id="ww-wheels-big" viewBox="0 0 400 200">
          <g fill="none" stroke="currentColor" stroke-width="5">
            <circle cx="100" cy="100" r="90"></circle>
            <circle cx="100" cy="100" r="14"></circle>
            <circle cx="300" cy="100" r="90"></circle>
            <circle cx="300" cy="100" r="14"></circle>
          </g>
        </symbol>
      </defs>
    </svg>

    <Header />
    <main
      class="flex-1"
      transition:name="page-content"
      transition:animate="slide"
    >
      <slot />
    </main>

    {!hideSponsors && <SponsorsSection />}

    <Footer slug={Astro.url.pathname.replace(/\//g, "-").slice(1) || "home"} />
  </body>
</html>
