{
  "$schema": "https://beta.frontmatter.codes/frontmatter.schema.json",
  "frontMatter.copilot.enabled": false,
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "clubs",
      "previewPath": "'clubs'",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": [
        {
          "name": "name",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "town",
          "type": "choice",
          "choices": [
            "Beveren",
            "Kruibeke",
            "Zwijndrecht",
            "Melsele",
            "Vrasene"
          ],
          "required": true
        },
        {
          "name": "shortDescription",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "logo",
          "type": "string",
          "single": true
        },
        {
          "name": "website",
          "type": "string",
          "single": true
        },
        {
          "name": "meetingPoint",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "meetingPointDetail",
          "type": "string",
          "single": true
        },
        {
          "name": "contactEmail",
          "type": "string",
          "single": true
        },
        {
          "name": "active",
          "type": "boolean",
          "default": true
        },
        {
          "name": "gender",
          "type": "choice",
          "choices": [
            "women",
            "men",
            "mixed"
          ]
        },
        {
          "name": "rides",
          "type": "list",
          "required": true
        }
      ]
    },
    {
      "name": "sponsors",
      "previewPath": "'sponsors'",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": [
        {
          "name": "name",
          "type": "string",
          "single": true,
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "single": true
        },
        {
          "name": "logo",
          "type": "string",
          "single": true
        },
        {
          "name": "website",
          "type": "string",
          "single": true
        },
        {
          "name": "tier",
          "type": "choice",
          "choices": [
            "gold",
            "silver",
            "bronze"
          ],
          "required": true
        },
        {
          "name": "order",
          "type": "number",
          "default": 99
        },
        {
          "name": "active",
          "type": "boolean",
          "default": true
        }
      ]
    },
    {
      "name": "events",
      "previewPath": "'events'",
      "pageBundle": false,
      "clearEmpty": true,
      "fields": []
    }
  ],
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.pageFolders": [
    {
      "title": "clubs",
      "path": "[[workspace]]/src/content/clubs",
      "contentTypes": [
        "clubs"
      ]
    },
    {
      "title": "sponsors",
      "path": "[[workspace]]/src/content/sponsors",
      "contentTypes": [
        "sponsors"
      ]
    },
    {
      "title": "events",
      "path": "[[workspace]]/src/content/events",
      "contentTypes": [
        "events"
      ]
    }
  ],
  "frontMatter.content.publicFolder": "public",
  "frontMatter.git.enabled": true
}